// --- INICIO SUB-MODULO: repl.nini ---
// repl.nini - Bucle Principal Interactivo

// Estado Global (La Memoria Inmortal)
enjambre = {}
objetivo_actual = null
estado_activo = verdadero

tarea iniciar_repl:
    mientras estado_activo:
        p = "<color=#ff1744>[#] </color><color=#ffffff>Revenant</color>"
        si globals.objetivo_actual != nulo:
            p = p + " <color=#424242>[</color><color=#ffea00>" + globals.objetivo_actual + "</color><color=#424242>]</color>"
        p = p + " <color=#00e5ff>> </color>"
        entrada = pedir(p)
        
        si entrada == "salir" or entrada == "exit" or entrada == "x" or entrada == "q":
            info("Apagando nucleo Revenant...")
            globals.estado_activo = falso
            
        osi entrada == "ayuda" or entrada == "help" or entrada == "h":
            columnas = ["Cmd", "Alias", "Accion"]
            filas = [
                ["ayuda", "h", "Muestra este panel"],
                ["objetivo", "o", "Fija un target en memoria"],
                ["recon", "r", "Ejecuta nmap automatizado"],
                ["asalto", "a", "Gana ejecucion (Metaxploit)"],
                ["vault", "v", "Lista el botin guardado"],
                ["intel", "i", "Cosecha secretos del target"],
                ["inject", "inj", "Auto-replica Revenant"],
                ["privesc", "p", "Busca vectores de Root"],
                ["red escanear", "re", "Busca hosts en subred"],
                ["red info", "ri", "Topologia del enjambre"],
                ["botnet info", "bi", "Estado del enjambre"],
                ["sesiones", "s", "Muestra shells activas"],
                ["salir", "x/q", "Apaga el framework"],
            ]
            tabla = construir_tabla(columnas, filas)
            print(tabla)
            
        osi entrada.indexOf("objetivo ") == 0 or entrada.indexOf("o ") == 0:
            partes = entrada.split(" ")
            si partes.len == 2:
                ip = resolver_objetivo(partes[1])
                si ip:
                    globals.objetivo_actual = ip
                    exito("Objetivo fijado en memoria: " + globals.objetivo_actual)
                sino:
                    error("Dominio/IP Invalida.")
            sino:
                error("Uso: o <ip> o objetivo <ip>")
                
        osi entrada == "sesiones" or entrada == "s":
            info("Sesiones activas en enjambre: " + enjambre.len)
            
        osi entrada == "recon" or entrada == "r":
            modulo_espectro_recon()
            
        osi entrada == "asalto" or entrada == "a":
            modulo_asalto_root()
            
        osi entrada == "botnet info" or entrada == "bi":
            modulo_botnet_info()
            
        osi entrada == "botnet saquear" or entrada == "bs":
            modulo_botnet_saquear()
            
        osi entrada == "botnet persistir" or entrada == "bp":
            modulo_botnet_persistir()
            
        osi entrada == "vault" or entrada == "v":
            listar_credenciales()
            
        osi entrada == "intel" or entrada == "i":
            modulo_intel_saquear()
            
        osi entrada == "red escanear" or entrada == "re":
            modulo_red_escanear()
            
        osi entrada == "red info" or entrada == "ri":
            modulo_red_info()
            
        osi entrada == "inject" or entrada == "inj":
            modulo_inyeccion_replicar()
            
        osi entrada == "privesc" or entrada == "p":
            modulo_escalada_analizar()
            
        osi entrada == "":
            continue
            
        sino:
            error("Comando '" + entrada + "' desconocido.")

// --- FIN SUB-MODULO: repl.nini ---
// --- INICIO SUB-MODULO: modulos/espectro.nini ---
// modulo espectro.nini - Reconocimiento Avanzado

tarea modulo_espectro_recon:
    si globals.objetivo_actual == null:
        error("Abotando: No hay ningun objetivo fijado en memoria. Usa 'objetivo <ip>'.")
        return
        
    info("Iniciando Mapeo Nmap Profundo sobre: " + globals.objetivo_actual)
    
    // Inyectamos el router en memoria
    mirar(globals.objetivo_actual)
    
    // La macro automatica 'escanear' de Nini depende internamente de 'target_ip' y 'router'
    globals.target_ip = globals.objetivo_actual
    escanear
    
    archivo_log = current_path + "/scan_" + target_ip + ".txt"
    resultado = get_shell.host_computer.File(archivo_log)
    
    si resultado:
        exito("Matriz de puertos obtenida y guardada localmente.")
        print(resultado.get_content)
    sino:
        error("Fallo critico al generar o leer el archivo de escaneo.")

// --- FIN SUB-MODULO: modulos/espectro.nini ---
// --- INICIO SUB-MODULO: modulos/asalto.nini ---
// modulo asalto.nini - Inyecciones Metaxploit

tarea modulo_asalto_root:
    si globals.objetivo_actual == null:
        error("Abotando: No hay ningun objetivo fijado. Usa 'objetivo <ip>'.")
        retornar
        
    puerto = pedir("Ingresa el puerto a vulnerar (dejalo vacio para el router 0): ")
    port_int = 0
    si puerto.len > 0: port_int = puerto.to_int
        
    info("Analizando " + globals.objetivo_actual + ":" + port_int + " mediante Vault...")
    
    // Detecci├│n de Router para Bounce
    es_router = falso
    r = obtener_router_objetivo(globals.objetivo_actual)
    si r: es_router = verdadero
    
    lan_target = nulo
    si es_router:
        alerta("┬ĪROUTER DETECTADO! Posibilidad de Salto (Bounce).")
        opcion = pedir("┬┐Deseas saltar a IP interna? (s/n): ")
        si opcion == "s":
            lan_target = pedir("Ingresa la IP interna del objetivo final: ")
            info("Configurando ataque de salto hacia: " + lan_target)

    // Intento de recuperaci├│n de cache
    lib_info = obtener_info_libreria(globals.objetivo_actual, port_int)
    
    vulns_cache = []
    si lib_info:
        vulns_cache = obtener_vulnerabilidades(lib_info.lib_name, lib_info.version)
    
    si vulns_cache.len > 0:
        exito("Vulnerabilidades recuperadas del Vault para " + lib_info.lib_name)
        recorrer vulns_cache como v:
            info("Explotando via Cache: " + v.area + " | " + v.vuln)
            sesion = explotar_directo(lib_info.metalib, v.area, v.vuln, lan_target)
            si typeof(sesion) == "shell" o typeof(sesion) == "computer":
                exito("Acceso obtenido via Vault Cache.")
                enjambre[globals.objetivo_actual] = sesion
                retornar
    
    // Si no hay cache or fallo, escaneo tradicional
    info("No hay cache operativa. Iniciando escaneo profundo...")
    vuln = buscar_vulnerabilidad(globals.objetivo_actual, port_int)
    
    si vuln:
        exito("Vulnerabilidad detectada: " + vuln.area + " | " + vuln.vuln)
        cachear_vulnerabilidad(vuln.metalib.lib_name, vuln.metalib.version, vuln.area, vuln.vuln)
        
        info("Ejecutando Pipeline de asalto...")
        sesion = vuln >> explotar("1337_password", lan_target)
        
        si typeof(sesion) == "shell" o typeof(sesion) == "computer":
            exito("Brecha abierta. Objetivo a├▒adido al enjambre.")
            enjambre[globals.objetivo_actual] = sesion
        sino:
            error("Ataque fallido.")
    sino:
        error("Objetivo invulnerable.")

// --- FIN SUB-MODULO: modulos/asalto.nini ---
