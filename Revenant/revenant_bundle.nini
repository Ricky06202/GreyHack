// --- INICIO SUB-MODULO: modulos/botnet.nini ---
// modulo botnet.nini - El Alma de Revenant

tarea modulo_botnet_info:
    si enjambre.len == 0:
        error("El enjambre esta vacio. Asalta algun objetivo primero.")
        return
        
    info("Desplegando estado del enjambre (" + enjambre.len + " nodos activos):")
    columnas = ["IP Victima", "Tipo Acceso"]
    filas = []
    
    para nodo en enjambre:
        ip_nodo = nodo.key
        sesion_hash = typeof(nodo.value)
        filas.push([ip_nodo, sesion_hash])
    
    tabla = construir_tabla(columnas, filas)
    print(tabla)

tarea modulo_botnet_saquear:
    si enjambre.len == 0:
        error("El enjambre esta vacio.")
        return
        
    info("Iniciando extraccion e iteracion masiva de diccionarios...")
    
    para nodo en enjambre:
        ip_nodo = nodo.key
        sesion = nodo.value
        
        computer_node = null
        si typeof(sesion) == "shell":
            computer_node = sesion.host_computer
        osi typeof(sesion) == "computer":
            computer_node = sesion
            
        si computer_node:
            info("Escaneando /etc/passwd en " + ip_nodo)
            archivo = computer_node.File("/etc/passwd")
            si archivo and archivo.has_permission("r"):
                exito("Sombra obtenida. Desplegando algoritmos crypto...")
                
                contenido_passwd = archivo.get_content
                // Usando macro cruda del auto-hacker API Nini
                crackear_diccionario(contenido_passwd)
                credenciales = __nini_res_crack
                
                si typeof(credenciales) == "map":
                    para cred en credenciales:
                        info("> [VULNERADO] Usuario: " + cred.key + " | Pass: " + cred.value)
                sino:
                    error("Fallo al inyectar auto-hacker crypto.")
            sino:
                error("Proteccion detectada en " + ip_nodo)

// --- FIN SUB-MODULO: modulos/botnet.nini ---
// --- INICIO SUB-MODULO: modulos/persistencia.nini ---
// modulos/persistencia.nini - Inyecci├│n de Demonios

tarea modulo_botnet_persistir:
    si enjambre.len == 0:
        error("El enjambre esta vacio.")
        return
        
    info("Inyectando Daemons Backdoor en " + enjambre.len + " subsistemas...")
    
    para nodo en enjambre:
        ip_nodo = nodo.key
        sesion = nodo.value
        
        computer_node = null
        si typeof(sesion) == "shell":
            computer_node = sesion.host_computer
        osi typeof(sesion) == "computer":
            computer_node = sesion
            
        si computer_node:
            info("Configurando persistencia remota en " + ip_nodo)
            
            // Verificamos permisos de Sysadmin
            carpeta_init = computer_node.File("/lib/")
                
            si carpeta_init and carpeta_init.has_permission("w"):
                exito("Privilegios root confirmados. Modificando cronjobs / Systemd.")
                
                // Construyendo archivo demonio malicioso en PC victima
                computer_node.touch("/lib/systemd/system/", "nrpe_revenant.service")
                
                archivo_fake = computer_node.File("/lib/systemd/system/nrpe_revenant.service")
                si archivo_fake:
                    archivo_fake.set_content("[Unit]\nDescription=Revenant Keeper\n[Service]\nExecStart=/bin/sh")
                
                exito("[INSTALADO] Troyano persistente en latencia sobre " + ip_nodo)
            sino:
                error("Proteccion ring-0 en " + ip_nodo + ". Requiere rooteado manual.")

// --- FIN SUB-MODULO: modulos/persistencia.nini ---
// --- INICIO SUB-MODULO: modulos/vault.nini ---
_vault_data = {"creds": {}, "vulns": {}}
_vault_k = "R3V3N4NT_S3CUR3"
_version = "STABLE"

tarea inicializar_vault:
    p = "/var/revenant"
    si no mirar(p): p = "./"
    ruta = p + "/vault.db"
    
    si mirar(ruta):
        f = obtener_archivo(ruta)
        contenido = f.get_content
        si contenido.len > 0:
            _vault_data = deserializar_vault(contenido)
            info("Vault cargado: " + _vault_data.creds.len + " creds, " + _vault_data.vulns.len + " vulns.")
    sino:
        info("Iniciando nuevo Vault en: " + ruta)

tarea cifrar(txt):
    res = ""
    recorrer txt como i:
        v = nini_xor(code(txt[i]), code(_vault_k[i % _vault_k.len]))
        res = res + v.to_str + ","
    retornar res

tarea descifrar(txt):
    res = ""
    partes = txt.split(",")
    recorrer partes como p:
        si p == "": continuar
        res = res + char(nini_xor(val(p), code(_vault_k[res.len % _vault_k.len])))
    retornar res

tarea serializar_vault(data):
    // Formato simple: creds|{...} \n vulns|{...}
    retornar cifrar(str(data))

tarea deserializar_vault(txt):
    raw = descifrar(txt)
    retornar val(raw)

tarea guardar_vault:
    p = "/var/revenant"
    si no mirar(p): p = "./"
    ruta = p + "/vault.db"
    f = obtener_archivo(ruta)
    si no f:
        // Crear si no existe
        tocar(p, "vault.db")
        f = obtener_archivo(ruta)
    
    f.set_content(serializar_vault(_vault_data))

tarea guardar_credencial(ip, usuario, clave, priv, lan):
    k = (ip + "_" + usuario + "_" + priv).lower()
    _vault_data.creds[k] = {"ip": ip, "user": usuario, "pass": clave, "priv": priv, "lan": lan}
    guardar_vault()
    exito("Vault actualizado: " + usuario + "@" + ip)

tarea listar_credenciales:
    columnas = ["IP", "Usuario", "Clave", "Priv", "LAN"]
    filas = []
    recorrer _vault_data.creds como k:
        c = _vault_data.creds[k]
        filas.push([c.ip, c.user, c.pass, c.priv, c.lan])
    
    print(construir_tabla(columnas, filas))

tarea cachear_vulnerabilidad(lib, ver, area, vuln):
    k = (lib + "_" + ver).lower()
    si no _vault_data.vulns.tiene(k): _vault_data.vulns[k] = []
    _vault_data.vulns[k].push({"area": area, "vuln": vuln})
    guardar_vault()

tarea obtener_vulnerabilidades(lib, ver):
    k = (lib + "_" + ver).lower()
    si _vault_data.vulns.tiene(k): retornar _vault_data.vulns[k]
    retornar []


// --- FIN SUB-MODULO: modulos/vault.nini ---
// --- INICIO SUB-MODULO: modulos/intel.nini ---
// modulos/intel.nini - Operaci├│n Cosecha Silenciosa ­¤īŠ­¤ÆĆ

tarea modulo_intel_saquear:
    si globals.objetivo_actual == null:
        error("Fije un objetivo primero.")
        retornar
        
    sesion = enjambre[globals.objetivo_actual]
    si no sesion:
        error("No hay sesion activa para " + globals.objetivo_actual + " en el enjambre.")
        retornar
        
    info("Iniciando extracci├│n de inteligencia profunda en " + globals.objetivo_actual)
    
    comp = nulo
    si typeof(sesion) == "shell": comp = sesion.host_computer
    sino: comp = sesion
    
    // 1. Cosechar /etc/passwd
    passwd = comp.File("/etc/passwd")
    si passwd y no passwd.is_binary:
        info("Procesando /etc/passwd...")
        lineas = passwd.get_content.split(char(10))
        recorrer lineas como l:
            si l.indexOf(":") == nulo: continuar
            partes = l.split(":")
            usuario = partes[0]
            hash = partes[1]
            si hash == "x" o hash == "*": continuar
            
            info("Descifrando hash de sistema: " + usuario)
            clave = crackear_hash(hash)
            si clave:
                guardar_credencial(globals.objetivo_actual, usuario, clave, "linux", comp.local_ip)
    
    // 2. Cosechar /home (Bancos y Correos)
    home = comp.File("/home")
    si home:
        recorrer home.get_folders como user_dir:
            usr = user_dir.name
            info("Explorando entorno de usuario: " + usr)
            
            // Bancos
            banco_file = comp.File("/home/" + usr + "/Config/Bank.txt")
            si banco_file:
                recorrer banco_file.get_content.split(char(10)) como l:
                    si l.indexOf(":") == nulo: continuar
                    p = l.split(":")
                    acc = p[0]; h = p[1]
                    pass_dec = crackear_hash(h)
                    si pass_dec: guardar_credencial(globals.objetivo_actual, acc, pass_dec, "banco", comp.local_ip)
            
            // Correos
            mail_file = comp.File("/home/" + usr + "/Config/Mail.txt")
            si mail_file:
                recorrer mail_file.get_content.split(char(10)) como l:
                    si l.indexOf(":") == nulo: continuar
                    p = l.split(":")
                    acc = p[0]; h = p[1]
                    pass_dec = crackear_hash(h)
                    si pass_dec: guardar_credencial(globals.objetivo_actual, acc, pass_dec, "correo", comp.local_ip)
    
    exito("Operaci├│n de inteligencia finalizada. Revisa el 'vault'.")

// --- FIN SUB-MODULO: modulos/intel.nini ---
// --- INICIO SUB-MODULO: modulos/red.nini ---
