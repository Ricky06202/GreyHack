// Test import_code functionality
print "Testing import_code..."

// First, check if file exists
comp = get_shell.host_computer
testFile = comp.File("/lib/wraith/test_module.src")
if not testFile then
    print "ERROR: test_module.src not found in /lib/wraith/"
    print "Current path: " + current_path
    // Try to find the file in current directory
    localFile = comp.File(current_path + "/test_module.src")
    if localFile then
        print "Found in current directory, trying relative import"
        testModule = import_code("./test_module.src")
    end if
else
    // Import the test module
    testModule = import_code("/lib/wraith/test_module.src")
end if

if typeof(testModule) == "map" then
    print "Module imported successfully"
    if testModule.hasIndex("sayHello") then
        result = testModule.sayHello("Grey Hack")
        print result
    else
        print "Module does not have sayHello function"
    end if
else
    print "Failed to import module, type: " + typeof(testModule)
end if