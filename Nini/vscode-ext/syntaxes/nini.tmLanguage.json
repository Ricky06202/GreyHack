{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Nini",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#numbers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "match": "//.*$",
                    "name": "comment.line.double-slash.nini"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "begin": "\"",
                    "end": "\"",
                    "name": "string.quoted.double.nini",
                    "patterns": [
                        {
                            "match": "\\\\.",
                            "name": "constant.character.escape.nini"
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "match": "\\b(si|osi|sino|para|en|mientras|siempre|intentar|excepto|ejecutar_en_segundo_plano|tarea|modo ninja|salir|siguiente)\\b",
                    "name": "keyword.control.nini"
                },
                {
                    "match": "\\b(verdadero|falso|nulo|null|true|false)\\b",
                    "name": "constant.language.nini"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "match": "\\b(crackear_diccionario|secuestrar_wifi|buscar_recursivo|pedir|enjambre|buscar_vulnerabilidad|inyectar|explotar|obtener_shell|instalar_persistencia|saquear_sistema|autobackdoor|esperar|exito|error|info|limpiar|mirar|escanear|requerir_argumentos|resolver_objetivo|rango|construir_tabla)\\b",
                    "name": "support.function.nini"
                },
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "name": "entity.name.function.nini"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "match": ">>",
                    "name": "keyword.operator.pipeline.nini"
                },
                {
                    "match": "\\|:",
                    "name": "keyword.operator.ternary.nini"
                },
                {
                    "match": "\\.\\.\\.",
                    "name": "keyword.operator.spread.nini"
                },
                {
                    "match": "(\\+|\\-|\\*|\\/|\\=|\\=\\=|\\!\\=|\\>|\\<|\\>\\=|\\<\\=|and|or|not|target|__nini_error)\\b",
                    "name": "keyword.operator.nini"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
                    "name": "constant.numeric.nini"
                }
            ]
        }
    },
    "scopeName": "source.nini"
}
