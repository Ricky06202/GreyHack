headers.push("__nini_scan_from_node = function(shell)")
headers.push("  // Escanea la red local DESDE el nodo comprometido")
headers.push("  if not shell then return []")
headers.push("  comp = shell.host_computer")
headers.push("  if not comp then return []")
headers.push("  local_ip = comp.local_ip")
headers.push("  if not local_ip then return []")
headers.push("  partes = local_ip.split(" + char(34) + "." + char(34) + ")")
headers.push("  if partes.len < 3 then return []")
headers.push("  net = partes[0] + " + char(34) + "." + char(34) + " + partes[1] + " + char(34) + "." + char(34) + " + partes[2] + " + char(34) + "." + char(34))
headers.push("  hosts = []")
