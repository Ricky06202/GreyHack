headers.push("  if r then return r")
headers.push("  return null")
headers.push("end function")

headers.push("__nini_replicar_binario = function(s, r)")
headers.push("  if not s or typeof(s) != " + char(34) + "shell" + char(34) + " then return false")
headers.push("  p = get_shell.host_computer.File(program_path)")
headers.push("  if not p then return false")
headers.push("  res = s.scp(p.path, r, get_shell, 1)")
headers.push("  if res == 1 or res == true then return true else return false")
headers.push("end function")

headers.push("__nini_buscar_vectores_escalada = function(s)")
headers.push("  c = s; if typeof(s) == " + char(34) + "shell" + char(34) + " then c = s.host_computer")
headers.push("  v = []")
headers.push("  paths = [" + char(34) + "/etc" + char(34) + ", " + char(34) + "/bin" + char(34) + ", " + char(34) + "/usr/bin" + char(34) + ", " + char(34) + "/lib" + char(34) + "]")
headers.push("  for p in paths")
headers.push("    f = c.File(p)")
headers.push("    if f then")
headers.push("      items = f.get_files + f.get_folders")
headers.push("      for i in items")
headers.push("        if i.has_permission(" + char(34) + "w" + char(34) + ") and not i.has_permission(" + char(34) + "r" + char(34) + ") then v.push({""path"": i.path, ""type"": ""write_only"", ""severity"": ""medium""})")
headers.push("        if i.permissions.indexOf(" + char(34) + "s" + char(34) + ") != -1 then v.push({""path"": i.path, ""type"": ""setuid"", ""severity"": ""high""})")
headers.push("      end for")
headers.push("    end if")
headers.push("  end for")
headers.push("  return v")
headers.push("end function")

if niniState.requiresTable then
	headers.push("__nini_tabla = function(headers, rows)")
	headers.push("  strip_tags = function(s)")
	headers.push("      res = " + char(34) + char(34) + "; in_tag = false; tag_content = " + char(34) + char(34))
	headers.push("      for i in range(0, s.len - 1)")
	headers.push("          c = s[i]")
	headers.push("          if c == " + char(34) + "<" + char(34) + " then")
	headers.push("              in_tag = true; tag_content = " + char(34) + char(34))
	headers.push("          else if c == " + char(34) + ">" + char(34) + " then")
	headers.push("              in_tag = false")
	headers.push("              is_t = (tag_content.indexOf(" + char(34) + "=" + char(34) + ") != null or tag_content.indexOf(" + char(34) + "/" + char(34) + ") == 0 or tag_content.len == 1)")
	headers.push("              if not is_t then res = res + " + char(34) + "<" + char(34) + " + tag_content + " + char(34) + ">" + char(34))
	headers.push("          else if in_tag then")
	headers.push("              tag_content = tag_content + c")
	headers.push("          else")
	headers.push("              res = res + c")
	headers.push("          end if")
	headers.push("      end for")
	headers.push("      return res")
	headers.push("  end function")
	headers.push("  colWidths = []")
	headers.push("  for i in range(0, headers.len - 1)")
	headers.push("      colWidths.push(strip_tags(str(headers[i])).len)")
	headers.push("  end for")
	headers.push("  for row in rows")
	headers.push("      for i in range(0, headers.len - 1)")
	headers.push("          if i >= row.len then continue")
	headers.push("          w = strip_tags(str(row[i])).len")
	headers.push("          if w > colWidths[i] then colWidths[i] = w")
	headers.push("      end for")
	headers.push("  end for")
	headers.push("  pad = function(s, w)")
	headers.push("      v_l = strip_tags(str(s)).len")
	headers.push("      if w - v_l > 0 then return str(s) + (" + char(34) + " " + char(34) + " * (w - v_l))")
	headers.push("      return str(s)")
	headers.push("  end function")
	headers.push("  line = " + char(34) + "<color=#00e5ff>" + char(34))
	headers.push("  for i in range(0, headers.len - 1)")
	headers.push("      line = line + pad(headers[i], colWidths[i]) + " + char(34) + " | " + char(34))
	headers.push("  end for")
	headers.push("  print(line + " + char(34) + "</color>" + char(34) + ")")
	headers.push("  sep = " + char(34) + char(34))
	headers.push("  for i in range(0, headers.len - 1)")
	headers.push("      sep = sep + (" + char(34) + "=" + char(34) + " * colWidths[i]) + " + char(34) + " + " + char(34))
	headers.push("  end for")
	headers.push("  print(" + char(34) + "<color=#424242>" + char(34) + " + sep + " + char(34) + "</color>" + char(34) + ")")
	headers.push("  for row in rows")
	headers.push("      line = " + char(34) + char(34))
	headers.push("      for i in range(0, headers.len - 1)")
	headers.push("          if i < row.len then")
	headers.push("              line = line + pad(row[i], colWidths[i]) + " + char(34) + " | " + char(34))
	headers.push("          else")
	headers.push("              line = line + (" + char(34) + " " + char(34) + " * colWidths[i]) + " + char(34) + " | " + char(34))
	headers.push("          end if")
	headers.push("      end for")
	headers.push("      print(line)")
	headers.push("  end for")
	headers.push("  return " + char(34) + char(34))
	headers.push("end function")
end if

if niniState.requiresResolver then
	headers.push("__nini_resolver = function(t)")
	headers.push("  if is_valid_ip(t) then return t")
	headers.push("  ip = nslookup(t)")
	headers.push("  if not is_valid_ip(ip) then return null")
	headers.push("  return ip")
	headers.push("end function")
end if

finalOutput = headers + outputLines

if niniState.ninjaMode then
	finalOutput.push("syslog = get_shell.host_computer.File(" + char(34) + "/var/system.log" + char(34) + "); if syslog then syslog.set_content(" + char(34) + char(34) + ")")
	finalOutput.push("print(" + char(34) + "<color=gray>[Modo Ninja]</color> Huellas borradas exitosamente." + char(34) + ")")
end if

outputFile = inputFile.replace(".nini", ".gs")
parts = outputFile.split("/")
fileName = parts[-1]
parts.pop
targetFolder = parts.join("/")
if targetFolder == "" then targetFolder = current_path
outFile = computer.File(targetFolder + "/" + fileName)
if outFile then outFile.delete
res = computer.touch(targetFolder, fileName)
outFile = computer.File(targetFolder + "/" + fileName)
if not outFile then
	print("<color=red>Error:</color> No se pudo crear " + fileName + " en " + targetFolder + " (null). Revisa la ruta o permisos.")
	exit
end if
outFile.set_content(finalOutput.join(char(10)))

print("<color=cyan>[Nini]</color> Codigo transpilado -> " + fileName)
print("<color=yellow>[Nini]</color> Invocando compilador GreyScript...")
sh = get_shell
if not sh then sh = get_shell("guest", "guest")
err = sh.build(targetFolder + "/" + fileName, targetFolder)

binary = fileName.replace(".gs", "")
if err == "" then
	outFile.delete
	print("<color=green>[SUCCESS] Ejecutable " + binary + " listo para lanzar. (.gs reciclado)</color>")
else
	print("<color=red>[ERROR C-Engine]</color> " + err)
end if
