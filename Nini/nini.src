headers.push("  if not c then return null")
headers.push("  return c.decipher(h)")
headers.push("end function")

headers.push("__nini_obtener_info_libreria = function(ip, p)")
headers.push("  m = include_lib(" + char(34) + "/lib/metaxploit.so" + char(34) + ")")
headers.push("  if not m then return null")
headers.push("  s = m.net_use(ip, p)")
headers.push("  if not s then return null")
headers.push("  l = s.dump_lib")
headers.push("  if not l then return null")
headers.push("  return {" + char(34) + "lib_name" + char(34) + ": l.lib_name, " + char(34) + "version" + char(34) + ": l.version, " + char(34) + "metalib" + char(34) + ": l}")
headers.push("end function")

headers.push("__nini_explotar_directo = function(lib, a, v, lan=null)")
