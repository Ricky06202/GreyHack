	headers.push("  if typeof(arg2) == ""map"" and arg2.hasIndex(""v_list"") then; v_o = arg2; p_e = arg1; lan = arg3; end if")
	headers.push("  if typeof(arg3) == ""map"" and arg3.hasIndex(""v_list"") then; v_o = arg3; p_e = arg1; lan = arg2; end if")
	headers.push("  if v_o != null then")
	headers.push("      for v in v_o[""v_list""]")
	headers.push("          res = __nini_explotar_directo(v_o[""metalib""], v[""mem""], v[""pass""], lan); if res then return res")
	headers.push("          if p_e != """" then; res = __nini_explotar_directo(v_o[""metalib""], v[""mem""], v[""pass""], p_e); if res then return res; end if")
