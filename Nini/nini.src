// nini.src - (Auto-Hacker APIs Edition)
// Transpilador Nini a MiniScript para Grey Hack

if params.len != 1 or params[0] == "-h" or params[0] == "--help" then
	print("Uso: nini [archivo.nini]")
	exit
end if

inputFile = params[0]
if inputFile.indexOf(".nini") == null then
	print("Error: El archivo debe tener la extension .nini")
	exit
end if

computer = get_shell.host_computer
file = computer.File(current_path + "/" + inputFile)
if not file then file = computer.File(inputFile)
if not file or not file.has_permission("r") then
	print("Error: No se pudo leer el archivo " + inputFile)
	exit
end if

content = file.get_content
lines = content.split(char(10))

logger = {}
logger.error = function(lineNum, msg)
	print("<color=red>[Error Sintaxis Nini]</color> Linea " + lineNum + ": " + msg)
	exit
end function

// Estado del Compilador
niniState = {}
niniState.globalTarget = ""
niniState.requiresMetaxploit = false
niniState.requiresCrypto = false
niniState.requiresAptClient = false
niniState.ninjaMode = false
niniState.requiresEnjambre = false
niniState.requiresExploiter = false
niniState.requiresTable = false
niniState.requiresUI = false
niniState.requiresFS = false
niniState.requiresWifi = false
niniState.requiresCracker = false
niniState.requiresResolver = false

// Motor de Expansión de Macros Nini
preprocessNiniMacros = function(s)
	if s.indexOf("resolver_objetivo") >= 0 then; niniState.requiresResolver = true; end if
	if s.indexOf("crackear_diccionario") >= 0 then; niniState.requiresCracker = true; niniState.requiresCrypto = true; end if
	if s.indexOf("secuestrar_wifi") >= 0 then; niniState.requiresWifi = true; niniState.requiresCrypto = true; end if
	if s.indexOf("buscar_recursivo") >= 0 then; niniState.requiresFS = true; end if
	if s.indexOf("pedir") >= 0 then; niniState.requiresUI = true; end if
	if s.indexOf("construir_tabla") >= 0 then; niniState.requiresTable = true; end if
	if s.indexOf("buscar_vulnerabilidad") >= 0 then; niniState.requiresExploiter = true; end if
	if s.indexOf("explotar") >= 0 then; niniState.requiresExploiter = true; end if
	return s
end function

niniState.requiresPersistencia = false
niniState.requiresFuzzer = false
niniState.requiresCracker = false
niniState.requiresWifi = false
niniState.requiresFS = false
niniState.requiresUI = false
niniState.requiresTable = false
niniState.requiresResolver = false
niniState.asyncCounter = 0

// Pila Estructural para Indentación
blockStack = []
outputLines = []

parseCommand = function(lineNum, trimmed, currentIndent)
	endsWithColon = (trimmed.len > 0 and trimmed[trimmed.len-1] == ":")
	trimmed = trimmed.replace("rango\(", "range(")
	trimmed = trimmed.replace("verdad", "true")
	trimmed = trimmed.replace("falso", "false")
	trimmed = trimmed.replace("nulo", "null")
	trimmed = trimmed.replace(" o ", " or ")
	trimmed = trimmed.replace(" y ", " and ")
	trimmed = trimmed.replace(" no ", " not ")
	trimmed = trimmed.replace("verdadero", "true")
	trimmed = preprocessNiniMacros(trimmed)

	// 0. OPERADOR SPREAD DE ARRAYS (...)
	if trimmed.indexOf("...") != null and trimmed.indexOf("[") != null then
		cleanLine = trimmed
		while cleanLine.indexOf("...") != null
			idx = cleanLine.indexOf("...")
			startBracket = cleanLine.lastIndexOf("[", idx)
			endBracket = cleanLine.indexOf("]", idx)
			if startBracket != null and endBracket != null and endBracket > startBracket then
				arrContent = cleanLine[startBracket+1:endBracket]
				parts = arrContent.split(",")
				res = []
				for p in parts
					p = p.trim
					if p.indexOf("...") == 0 then
						res.push(p.replace("...", ""))
					else
						res.push("[" + p + "]")
					end if
				end for
				joined = res.join(" + ")
				cleanLine = cleanLine[:startBracket] + joined + cleanLine[endBracket+1:]
			else
				break
			end if
		end while
		trimmed = cleanLine
	end if

	// 1. CONTEXTO GLOBAL
	if trimmed.indexOf("target = ") == 0 then
		val = trimmed.replace("target = ", "").trim
		niniState.globalTarget = val
		return "target_ip = " + val
	end if

	// 2. PIPELINES
	cleanS = ""; inQ = false; for char_idx in range(0, trimmed.len - 1)
		c = trimmed[char_idx]; if c == char(34) then inQ = not inQ
		if inQ then cleanS = cleanS + "_" else cleanS = cleanS + c
	end for
	
	if cleanS.indexOf(" >> ") != null then
		finalVar = ""
		pipelineData = trimmed
		cleanPipe = cleanS
		if cleanPipe.indexOf(" = ") != null and cleanPipe.indexOf(" = ") < cleanPipe.indexOf(" >> ") then
			eqIdx = cleanPipe.indexOf(" = ")
			finalVar = trimmed[:eqIdx].trim
			pipelineData = trimmed[eqIdx + 3:].trim
			cleanPipe = cleanPipe[eqIdx + 3:].trim
		end if

		parts = pipelineData.split(" >> ")
		pipeLines = []
		for p in range(0, parts.len - 1)
			part = preprocessNiniMacros(parts[p].trim)
			if p == 0 then
				pipeLines.push("_pipe" + p + " = " + part)
			else
				prevPipe = "_pipe" + (p - 1)
				currPipe = "_pipe" + p
				if p == parts.len - 1 then
					if finalVar != "" then prefix = finalVar + " = " else prefix = ""
				else
					prefix = currPipe + " = "
				end if
				
				part = parts[p].trim
				if part.indexOf("(") == null then
					pipeLines.push(prefix + part + "(" + prevPipe + ")")
				else
					lastParen = part.lastIndexOf(")")
					before = part[:lastParen]
					after = part[lastParen:]
					bTr = before.trim
					sep = ", "
					if bTr.len > 0 and bTr[bTr.len-1] == "(" then sep = ""
					pipeLines.push(prefix + before + sep + prevPipe + after)
				end if
			end if
		end for
		return pipeLines.join(char(10))
	end if

	// 3. ESTRUCTURAS DE CONTROL SINTAXIS NATURAL
	// 3. ESTRUCTURAS DE CONTROL SINTAXIS NATURAL
	if cleanS.indexOf("si ") == 0 and cleanS.indexOf(":") != null then
		colIdx = cleanS.indexOf(":")
		cond = trimmed[3 : colIdx].trim
		accion = trimmed[colIdx + 1 :].trim
		if accion.len == 0 then
			blockStack.push({"bType": "if", "indent": currentIndent})
			return "if (" + cond + ") then"
		else
			return "if (" + cond + ") then; " + accion + "; end if"
		end if
	end if
	
	if cleanS.indexOf("osi ") == 0 and cleanS.indexOf(":") != null then
		colIdx = cleanS.indexOf(":")
		cond = trimmed[4 : colIdx].trim
		accion = trimmed[colIdx + 1 :].trim
		if accion.len == 0 then
			return "else if (" + cond + ") then"
		else
			return "else if (" + cond + ") then; " + accion + "; end if"
		end if
	end if

	if cleanS == "sino:" or cleanS.indexOf("sino: ") == 0 then
		colIdx = cleanS.indexOf(":")
		accion = trimmed[colIdx + 1 :].trim
		if accion.len == 0 then
			return "else"
		else
			return "else; " + accion
		end if
	end if
	if (trimmed.indexOf("recorrer ") == 0 or trimmed.indexOf("para ") == 0) and (trimmed.indexOf(" como ") != null or trimmed.indexOf(" en ") != null) and endsWithColon then
		middle = trimmed.indexOf(" como ")
		if middle == null then middle = trimmed.indexOf(" en ")
		keywordLen = 9 // "recorrer "
		sepLen = 6 // " como "
		if trimmed.indexOf("para ") == 0 then; keywordLen = 5; sepLen = 4; end if
		
		item = trimmed[keywordLen : middle].trim
		collection = trimmed[middle + sepLen : trimmed.len-1].trim
		blockStack.push({"bType": "for", "indent": currentIndent})
		return "for " + item + " in " + collection
	end if
	if trimmed.indexOf("mientras ") == 0 and endsWithColon then
		cond = trimmed[9 : trimmed.len-1].trim
		blockStack.push({"bType": "while", "indent": currentIndent})
		return "while (" + cond + ")"
	end if
	if trimmed == "siempre:" then
		blockStack.push({"bType": "while", "indent": currentIndent})
		return "while true"
	end if
	if trimmed == "intentar:" then
		blockStack.push({"bType": "try_raw", "indent": currentIndent})
		return "__nini_error = false"
	end if
	if trimmed == "excepto:" then
		if blockStack.len > 0 and blockStack[-1].bType == "try_raw" then
			blockStack.pop
			blockStack.push({"bType": "try_catch", "indent": currentIndent})
			return "if __nini_error then"
		else
			logger.error(lineNum, "excepto: usado sin un bloque intentar: previo.")
		end if
	end if
	
	// ASINCRONIA (Hilos Background)
	if trimmed == "ejecutar_en_segundo_plano:" then
		blockStack.push({"bType": "async_bg", "indent": currentIndent})
		niniState.asyncCounter = niniState.asyncCounter + 1
		return "host = get_shell.host_computer; host.touch(current_path, ""__bg_task_" + niniState.asyncCounter + ".gs""); bg = host.File(current_path + ""/__bg_task_" + niniState.asyncCounter + ".gs""); bg_code_" + niniState.asyncCounter + " = []"
	end if

	// NINI UTILS
	if trimmed.indexOf("requerir_argumentos(") == 0 then
		startIdx = trimmed.indexOf("(") + 1
		endIdx = trimmed.lastIndexOf(")")
		args_str = trimmed[startIdx:endIdx]
		args = args_str.split(",")
		out = []
		out.push("if params.len < " + args.len + " or (params.len > 0 and (params[0] == " + char(34) + "-h" + char(34) + " or params[0] == " + char(34) + "--help" + char(34) + ")) then")
		usageStr = []
		for a in args; usageStr.push("[" + a.replace(char(34), "").trim + "]"); end for
		out.push("  print(" + char(34) + "<color=yellow>Uso:</color> " + char(34) + " + program_path.split(" + char(34) + "/" + char(34) + ")[-1] + " + char(34) + " " + usageStr.join(" ") + char(34) + ")")
		out.push("  exit")
		out.push("end if")
		for i in range(0, args.len - 1)
			vName = "arg_" + args[i].replace(char(34), "").trim.replace(" ", "_").lower
			out.push(vName + " = params[" + i + "]")
		end for
		return out.join(char(10))
	end if

	// NINI AUTO-HACKER APIs (Pre-procesadas al inicio)


	// NINI AUTO-HACKER APIs
	// NINI-WRAITH OS (ENJAMBRE)

	if trimmed.indexOf("enjambre.") >= 0 then
		niniState.requiresEnjambre = true
		if trimmed.indexOf("enjambre.añadir") >= 0 then return trimmed.replace("enjambre.añadir", "__nini_enjambre.push")
		if trimmed.indexOf("enjambre.ejecutar_todo(") == 0 then
			cmd = trimmed[23 : trimmed.len-1].trim
			return "__nini_enjambre_ejecutar(" + cmd + ")"
		end if
	end if

	// EXPLOIT BUILDER y FUZZER
	// EXPLOIT BUILDER y FUZZER

	if trimmed.indexOf("inyectar(") == 0 then
		niniState.requiresFuzzer = true
		startIdx = trimmed.indexOf("(") + 1
		endIdx = trimmed.lastIndexOf(")")
		args_str = trimmed[startIdx:endIdx]
		args = args_str.split(",")
		lib = args[0].trim
		if args.len > 1 then req = args[1].trim else req = """"""
		return "__nini_fuzz_inyectar(" + lib + ", " + req + ")"
	end if
	if trimmed.indexOf("explotar(") >= 0 then
		niniState.requiresExploiter = true
		return trimmed.replace("explotar", "__nini_explotar")
	end if
	if trimmed == "obtener_shell" or trimmed.indexOf("obtener_shell(") >= 0 then
		niniState.requiresExploiter = true
		return trimmed.replace("obtener_shell", "__nini_obtener_shell")
	end if

	// PERSISTENCIA
	if trimmed.indexOf("instalar_persistencia(") == 0 then
		niniState.requiresPersistencia = true
		return trimmed.replace("instalar_persistencia", "__nini_instalar_persistencia")
	end if

	// FUNCIONALIDADES PRO V6
	if trimmed == "modo ninja:" then
		niniState.ninjaMode = true
		return "// Modo Ninja Activado"
	end if
	if trimmed.indexOf("tarea ") == 0 and endsWithColon then
		funName = trimmed[6 : trimmed.len-1].trim
		blockStack.push({"bType": "function", "indent": currentIndent})
		return funName + " = func" + "tion()"
	end if
	if trimmed == "saquear_sistema" then
		return "files = [""/etc/shadow"", ""/etc/passwd"", ""/var/system.log""]; for f in files; file = get_shell.host_computer.File(f); if file then print(""<color=yellow>Robado:</color> "" + f + "" -> "" + file.get_content); end for"
	end if
	if trimmed == "autobackdoor" then
		niniState.requiresMetaxploit = true
		macroCode = [
			"print(""<color=#FF0000>[Autobackdoor]</color> Iniciando cadena de ataque en "" + target_ip)",
			"metaxploit = include_lib(""/lib/metaxploit.so"")",
			"net_session = metaxploit.net_use(target_ip)",
			"if net_session then",
			"    print(""Conexion establecida. Verificando privilegios..."")",
			"    shadow = get_shell.host_computer.File(""/etc/shadow"")",
			"    if shadow then print(""Shadow dump: "" + shadow.get_content) else print(""Sin acceso a shadow"")",
			"    print(""Limpiando huellas criticas..."")",
			"    syslog = get_shell.host_computer.File(""/var/system.log"")",
			"    if syslog then syslog.set_content("""")",
			"else",
			"    __nini_error = true",
			"    print(""<color=red>Invasion fallida</color>"")",
			"end if",
		]
		return macroCode.join(char(10))
	end if
	
	// UTILIDADES Y ABSTRACCIONES
	if trimmed == "salir" then return "break"
	if trimmed == "siguiente" then return "continue"
	if trimmed.indexOf("esperar(") == 0 then return trimmed.replace("esperar", "wait")
	if trimmed.indexOf("exito(") == 0 then return "print(""<color=#00ff41>[✔] </color><color=#ffffff>"" + " + trimmed[6:trimmed.len-1] + " + ""</color>"")"
	if trimmed.indexOf("error(") == 0 then return "print(""<color=#ff1744>[X] </color><color=#ffffff>"" + " + trimmed[6:trimmed.len-1] + " + ""</color>"")"
	if trimmed.indexOf("info(") == 0 then return "print(""<color=#00e5ff>[#] </color><color=#ffffff>"" + " + trimmed[5:trimmed.len-1] + " + ""</color>"")"
	if trimmed.indexOf("exito(") == 0 then return "print(""<color=#00e5ff>[+] </color><color=#ffffff>"" + " + trimmed[6:trimmed.len-1] + " + ""</color>"")"
	if trimmed.indexOf("alerta(") == 0 then return "print(""<color=#ffea00>[!] </color><color=#ffffff>"" + " + trimmed[7:trimmed.len-1] + " + ""</color>"")"
	if trimmed.indexOf("nini_xor(") != null then return trimmed.replace("nini_xor\(", "__nini_xor(")
	if trimmed.indexOf("crackear_hash(") != null then return trimmed.replace("crackear_hash\(", "__nini_crackear_hash(")
	if trimmed.indexOf("obtener_info_libreria(") != null then return trimmed.replace("obtener_info_libreria\(", "__nini_obtener_info_libreria(")
	if trimmed.indexOf("explotar_directo(") != null then return trimmed.replace("explotar_directo\(", "__nini_explotar_directo(")
	if trimmed.indexOf("descubrir_red_local(") != null then return trimmed.replace("descubrir_red_local\(", "__nini_descubrir_red_local(")
	if trimmed.indexOf("obtener_router_objetivo(") != null then return trimmed.replace("obtener_router_objetivo\(", "__nini_obtener_router_objetivo(")
	if trimmed.indexOf("replicar_binario(") != null then return trimmed.replace("replicar_binario\(", "__nini_replicar_binario(")
	if trimmed.indexOf("buscar_vectores_escalada(") != null then return trimmed.replace("buscar_vectores_escalada\(", "__nini_buscar_vectores_escalada(")
	if trimmed == "limpiar" or trimmed == "clean_house" then return "syslog = get_shell.host_computer.File(" + char(34) + "/var/system.log" + char(34) + "); if syslog then syslog.set_content(" + char(34) + char(34) + ")"
	if trimmed.indexOf("mirar(") == 0 then
		arg = trimmed[trimmed.indexOf("(")+1:trimmed.lastIndexOf(")")].trim
		return "router = get_router(" + arg + "); if router then ports = router.used_ports else __nini_error = true"
	end if
	
	if trimmed == "escanear" then
		niniState.requiresMetaxploit = true
		macroCode = [
			"print(""<color=#00FF00>[Nini]</color> Iniciando escaneo en "" + target_ip)",
			"metaxploit = include_lib(""/lib/metaxploit.so"")",
			"net_session = metaxploit.net_use(target_ip)",
			"if not net_session then __nini_error = true",
			"scan_results = []",
			"router = get_router(target_ip)",
			"if router then",
			"    ports = router.used_ports",
			"    for port in ports",
			"        net_session = metaxploit.net_use(target_ip, port.port_number)",
			"        if net_session then",
			"            lib = net_session.dump_lib",
			"            scan_results.push(""Port: "" + port.port_number + "" Version: "" + lib.version)",
			"        end if",
			"    end for",
			"end if",
			"f = get_shell.host_computer.File(current_path + ""/scan_"" + target_ip + "".txt"")",
			"if not f then",
			"    get_shell.host_computer.touch(current_path, ""scan_"" + target_ip + "".txt"")",
			"    f = get_shell.host_computer.File(current_path + ""/scan_"" + target_ip + "".txt"")",
			"end if",
			"if f then f.set_content(scan_results.join(char(10)))",
		]
		return macroCode.join(char(10))
	end if
	
	// NULL-SAFETY (Ghost Objects Wrapper)
	if trimmed.indexOf("=") == null and trimmed.indexOf(".") > 0 and trimmed.indexOf("(") > 0 and trimmed[trimmed.len-1] == ")" and trimmed.indexOf("print(") != 0 then
		objName = trimmed[:trimmed.indexOf(".")]
		if objName.indexOf("""") == null and objName.indexOf(" ") == null then
			return "if " + objName + " != null then " + trimmed + " else print(""<color=yellow>[Nini]</color> Objeto nulo omitido ("" + """ + objName + """ + "") en linea " + lineNum + """)"
		end if
	end if

	// Passthrough general abierto (Variables, llamadas funciones de usuario, APIs nativas)
	return trimmed
end function

print("Iniciando transpilacion Nini...")

for i in range(0, lines.len)
	if i >= lines.len then break
	rawLine = lines[i]
	trimmed = rawLine.trim
	
	if trimmed == "" or trimmed.indexOf("//") == 0 then continue
	
	currentIndent = 0
	for char_idx in range(0, rawLine.len - 1)
		c = rawLine[char_idx]
		if c == " " or c == char(9) then currentIndent = currentIndent + 1 else break
	end for
	
	isContinuation = (trimmed.indexOf("osi ") == 0) or (trimmed == "sino:") or (trimmed == "excepto:")
	
	while blockStack.len > 0
		topBlock = blockStack[-1]
		if currentIndent < topBlock.indent or (currentIndent == topBlock.indent and not isContinuation) then
			b = blockStack.pop
			if b.bType == "if" then 
				outputLines.push("en" + "d if")
			else if b.bType == "while" then 
				outputLines.push("en" + "d while")
			else if b.bType == "for" then 
				outputLines.push("en" + "d for")
			else if b.bType == "try_catch" then 
				outputLines.push("en" + "d if")
			else if b.bType == "function" then 
				outputLines.push("en" + "d function")
			else if b.bType == "async_bg" then
				bgIdx = niniState.asyncCounter
				outputLines.push("if bg then bg.set_content(bg_code_" + bgIdx + ".join(char(10)))")
				outputLines.push("get_shell.build(current_path + " + char(34) + "/__bg_task_" + bgIdx + ".gs" + char(34) + ", current_path)")
				outputLines.push("get_shell.launch(current_path + " + char(34) + "/__bg_task_" + bgIdx + char(34) + ", " + char(34) + char(34) + ")")
				outputLines.push("if bg then bg.delete()")
				outputLines.push("bgBin = host.File(current_path + " + char(34) + "/__bg_task_" + bgIdx + char(34) + ")")
				outputLines.push("if bgBin then bgBin.delete()")
			end if
		else
			break
		end if
	end while

	transpiledLine = parseCommand(i + 1, trimmed, currentIndent)
	if transpiledLine != "" then
		isAsync = false
		for b in blockStack
			if b.bType == "async_bg" then isAsync = true
		end for
		
		if isAsync and trimmed != "ejecutar_en_segundo_plano:" then
			linesStr = transpiledLine.split(char(10))
			for ls in linesStr
				outputLines.push("bg_code_" + niniState.asyncCounter + ".push(""" + ls.replace("""", """""") + """)")
			end for
		else
			linesStr = transpiledLine.split(char(10))
			for ls in linesStr
				outputLines.push(ls)
			end for
		end if
	end if
end for

// Cierre de bloques restantes
while blockStack.len > 0
	b = blockStack.pop
	if b.bType == "if" then 
		outputLines.push("en" + "d if")
	else if b.bType == "while" then 
		outputLines.push("en" + "d while")
	else if b.bType == "for" then 
		outputLines.push("en" + "d for")
	else if b.bType == "try_catch" then 
		outputLines.push("en" + "d if")
	else if b.bType == "function" then 
		outputLines.push("en" + "d function")
	else if b.bType == "async_bg" then
		bgIdx = niniState.asyncCounter
		outputLines.push("if bg then bg.set_content(bg_code_" + bgIdx + ".join(char(10)))")
		outputLines.push("get_shell.build(current_path + " + char(34) + "/__bg_task_" + bgIdx + ".gs" + char(34) + ", current_path)")
		outputLines.push("get_shell.launch(current_path + " + char(34) + "/__bg_task_" + bgIdx + char(34) + ", " + char(34) + char(34) + ")")
		outputLines.push("if bg then bg.delete()")
		outputLines.push("bgBin = host.File(current_path + " + char(34) + "/__bg_task_" + bgIdx + char(34) + ")")
		outputLines.push("if bgBin then bgBin.delete()")
	end if
end while

headers = []
if niniState.requiresMetaxploit or niniState.requiresExploiter or niniState.requiresFuzzer then
	headers.push("metaxploit = include_lib(" + char(34) + "/lib/metaxploit.so" + char(34) + "); if not metaxploit then exit(" + char(34) + "Motor Nini: falta metaxploit.so" + char(34) + ")")
end if
if niniState.requiresCrypto then
	headers.push("crypto = include_lib(" + char(34) + "/lib/crypto.so" + char(34) + "); if not crypto then exit(" + char(34) + "Motor Nini: falta crypto.so" + char(34) + ")")
end if

// NINI-WRAITH INJECTIONS
if niniState.requiresEnjambre then
	headers.push("__nini_enjambre = []")
	headers.push("__nini_enjambre_ejecutar = function(cmd)")
	headers.push("  for sh in __nini_enjambre")
	headers.push("      if typeof(sh) == ""shell"" then")
	headers.push("          if cmd == ""limpiar"" then")
	headers.push("              syslog = sh.host_computer.File(""/var/system.log"")")
	headers.push("              if syslog then syslog.set_content("""")")
	headers.push("          else")
	headers.push("              sh.launch(""/bin/"" + cmd, """")")
	headers.push("          end if")
	headers.push("      end if")
	headers.push("  end for")
	headers.push("end function")
end if

if niniState.requiresExploiter then
	headers.push("__nini_buscar_vulnerabilidad = function(ip, port)")
	headers.push("  ns = metaxploit.net_use(ip, 1*port); if not ns then return null")
	headers.push("  lib = ns.dump_lib; mems = metaxploit.scan(lib); v_list = []")
	headers.push("  for m in mems")
	headers.push("    rep = metaxploit.scan_address(lib, m); pts = rep.split(""<b>"")")
	headers.push("    for p in pts")
	headers.push("      if p.indexOf(""</b>"") == -1 then continue")
	headers.push("      v_list.push({""mem"": m, ""pass"": p.split(""</b>"")[0]})")
	headers.push("    end for")
	headers.push("  end for")
	headers.push("  if v_list.len == 0 then return null")
	headers.push("  return {""metalib"": lib, ""v_list"": v_list}")
	headers.push("end function")
	
	headers.push("__nini_explotar = function(arg1, arg2, arg3=null)")
	headers.push("  v_o = null; p_e = """"")
	headers.push("  if typeof(arg1) == ""map"" and arg1.hasIndex(""v_list"") then; v_o = arg1; p_e = arg2; end if")
	headers.push("  if typeof(arg2) == ""map"" and arg2.hasIndex(""v_list"") then; v_o = arg2; p_e = arg1; end if")
	headers.push("  if v_o != null then")
	headers.push("      for v in v_o.v_list")
	headers.push("          res = v_o.metalib.overflow(v.mem, v.pass, arg3); if res then return res")
	headers.push("          if p_e != """" then; res = v_o.metalib.overflow(v.mem, p_e, arg3); if res then return res; end if")
	headers.push("      end for; return null")
	headers.push("  end if")
	headers.push("  ns = metaxploit.net_use(globals.target_ip, str(arg1).to_int)")
	headers.push("  if ns then return ns.dump_lib else return null")
	headers.push("end function")
	
	headers.push("__nini_obtener_shell = function(obj)")
	headers.push("  if typeof(obj) == ""shell"" then obj.start_terminal")
	headers.push("  if typeof(obj) == ""computer"" then obj.get_shell(""root"",""root"")")
	headers.push("end function")
end if

