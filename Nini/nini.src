if niniState.requiresTable then
	headers.push("__nini_tabla = function(headers, rows)")
	headers.push("  // Strip tags para calcular anchos visibles")
	headers.push("  strip = function(s)")
	headers.push("      res = " + char(34) + char(34))
	headers.push("      in_tag = false")
	headers.push("      if s.len == 0 then return res")
	headers.push("      for i in range(0, s.len - 1)")
	headers.push("          c = s[i]")
	headers.push("          if c == " + char(34) + "<" + char(34) + " then")
	headers.push("              in_tag = true")
	headers.push("          else")
	headers.push("              if c == " + char(34) + ">" + char(34) + " then")
	headers.push("                  in_tag = false")
	headers.push("              else")
	headers.push("                  if not in_tag then res = res + c")
	headers.push("              end if")
	headers.push("          end if")
	headers.push("      end for")
	headers.push("      return res")
	headers.push("  end function")
	headers.push("  // Calcular anchos de columna")
	headers.push("  widths = []")
	headers.push("  for i in range(0, headers.len - 1)")
	headers.push("      widths.push(strip(str(headers[i])).len)")
	headers.push("  end for")
	headers.push("  for row in rows")
	headers.push("      for i in range(0, row.len - 1)")
	headers.push("          if i >= widths.len then continue")
	headers.push("          w = strip(str(row[i])).len")
	headers.push("          if w > widths[i] then widths[i] = w")
	headers.push("      end for")
	headers.push("  end for")
	headers.push("  // Funcion de padding")
	headers.push("  pad = function(s, w)")
	headers.push("      result = str(s)")
	headers.push("      while strip(result).len < w")
	headers.push("          result = result + " + char(34) + " " + char(34))
	headers.push("      end while")
	headers.push("      return result")
	headers.push("  end function")
	headers.push("  // Imprimir header con color")
	headers.push("  line = " + char(34) + "<color=#00e5ff>" + char(34))
	headers.push("  for i in range(0, headers.len - 1)")
	headers.push("      if i > 0 then line = line + " + char(34) + " | " + char(34))
	headers.push("      line = line + pad(str(headers[i]), widths[i])")
	headers.push("  end for")
	headers.push("  print(line + " + char(34) + "</color>" + char(34) + ")")
	headers.push("  // Imprimir separador elegante")
	headers.push("  sep = " + char(34) + char(34))
	headers.push("  for i in range(0, widths.len - 1)")
	headers.push("      if i > 0 then sep = sep + " + char(34) + "-+-" + char(34))
	headers.push("      for j in range(0, widths[i] - 1)")
	headers.push("          sep = sep + " + char(34) + "-" + char(34))
	headers.push("      end for")
	headers.push("  end for")
	headers.push("  print(" + char(34) + "<color=#424242>" + char(34) + " + sep + " + char(34) + "</color>" + char(34) + ")")
	headers.push("  // Imprimir filas")
	headers.push("  for row in rows")
	headers.push("      line = " + char(34) + char(34))
	headers.push("      for i in range(0, widths.len - 1)")
	headers.push("          if i > 0 then line = line + " + char(34) + " | " + char(34))
	headers.push("          if i < row.len then")
	headers.push("              line = line + pad(str(row[i]), widths[i])")
	headers.push("          else")
	headers.push("              line = line + pad(" + char(34) + char(34) + ", widths[i])")
	headers.push("          end if")
	headers.push("      end for")
	headers.push("      print(line)")
	headers.push("  end for")
	headers.push("  return " + char(34) + char(34))
	headers.push("end function")
end if

