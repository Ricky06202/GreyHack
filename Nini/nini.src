// ==================== LIMPIEZA DE HUELLAS ====================
headers.push("// --- LIMPIEZA DE HUELLAS (metodo touch) ---")
headers.push("__nini_limpiar_logs = function(shell=null)")
headers.push("  // Limpia logs borrando y recreando con touch (archivo en blanco sin rastros)")
headers.push("  if not shell then shell = get_shell")
headers.push("  comp = shell.host_computer")
headers.push("  if not comp then return 0")
headers.push("  logs = [")
headers.push("    " + char(34) + "/var/system.log" + char(34) + ",")
headers.push("    " + char(34) + "/var/log/syslog" + char(34) + ",")
headers.push("    " + char(34) + "/var/log/auth.log" + char(34) + ",")
headers.push("  ]")
headers.push("  cont = 0")
headers.push("  for ruta in logs")
headers.push("    partes = ruta.split(" + char(34) + "/" + char(34) + ")")
headers.push("    nombre = partes[-1]")
headers.push("    carpeta = " + char(34) + "/" + char(34))
headers.push("    if partes.len > 2 then carpeta = partes[0:partes.len-1].join(" + char(34) + "/" + char(34) + ")")
headers.push("    archivo = comp.File(ruta)")
headers.push("    if archivo then")
headers.push("      archivo.delete")
headers.push("      comp.touch(carpeta, nombre)")
headers.push("      cont = cont + 1")
headers.push("    end if")
headers.push("  end for")
headers.push("  return cont")
headers.push("end function")

