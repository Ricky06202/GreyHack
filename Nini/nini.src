	headers.push("end function")
end if

headers.push("__nini_xor = function(a, b)")
headers.push("  res = 0; p = 1")
headers.push("  while a > 0 or b > 0")
headers.push("    a_bit = a % 2; b_bit = b % 2")
headers.push("    if a_bit != b_bit then res = res + p")
headers.push("    a = floor(a / 2); b = floor(b / 2); p = p * 2")
headers.push("  end while")
headers.push("  return res")
headers.push("end function")

headers.push("__nini_crackear_hash = function(h)")
