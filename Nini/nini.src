headers.push("  return lib.overflow(a, v)")
headers.push("end function")

headers.push("__nini_descubrir_red_local = function()")
headers.push("  c = get_shell.host_computer")
headers.push("  lip = c.local_ip")
headers.push("  parts = lip.split(" + char(34) + "." + char(34) + ")")
headers.push("  if parts.len < 3 then return []")
headers.push("  net = parts[0:3].join(" + char(34) + "." + char(34) + ") + " + char(34) + "." + char(34))
headers.push("  h = []")
headers.push("  for i in range(1, 254)")
headers.push("    ip = net + i")
headers.push("    if ip == lip then continue")
headers.push("    if get_shell.ping(ip) == 1 then h.push(ip)")
headers.push("  end for")
headers.push("  return h")
headers.push("end function")

headers.push("__nini_obtener_router_objetivo = function(ip)")
