	headers.push("  crypto.airmon(""start"", iface)")
	headers.push("  networks = computer.wifi_networks(iface)")
	headers.push("  if not networks or networks.len == 0 then return null")
	headers.push("  parts = networks[0].split(" + char(34) + " " + char(34) + ")")
	headers.push("  bssid = parts[0]; essid = parts[2]")
	headers.push("  print(" + char(34) + "<color=yellow>[WiFi]</color> Inyectando en " + char(34) + " + bssid)")
	headers.push("  crypto.aireplay(bssid, essid, 300000)")
	headers.push("  res = crypto.aircrack(current_path + ""/file.cap"")")
	headers.push("  return res")
	headers.push("end function")
end if

if niniState.requiresFS then
	headers.push("__nini_buscar = function(fileName)")
	headers.push("  host = get_shell.host_computer")
	headers.push("  stack = [host.File(""/"")]")
	headers.push("  while stack.len > 0")
	headers.push("      curr = stack.pop()")
	headers.push("      if curr.is_folder then")
	headers.push("          for f in curr.get_folders()")
	headers.push("              stack.push(f)")
	headers.push("          end for")
	headers.push("          for f in curr.get_files()")
	headers.push("              if f.name == fileName then return f")
	headers.push("          end for")
	headers.push("      else")
	headers.push("          if curr.name == fileName then return curr")
	headers.push("      end if")
	headers.push("  end while")
	headers.push("  return null")
	headers.push("end function")
end if

